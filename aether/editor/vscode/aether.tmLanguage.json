{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aether",
  "scopeName": "source.aether",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#literals" },
    { "include": "#cons-pattern" },
    { "include": "#typed-pointer" },
    { "include": "#storage-keywords" },
    { "include": "#control-keywords" },
    { "include": "#primitive-types" },
    { "include": "#function-definitions" },
    { "include": "#actor-definitions" },
    { "include": "#struct-definitions" },
    { "include": "#message-definitions" },
    { "include": "#qualified-calls" },
    { "include": "#function-calls" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.aether",
          "begin": "//",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.aether" } },
          "end": "$"
        },
        {
          "name": "comment.block.aether",
          "begin": "/\\*",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.aether" } },
          "end": "\\*/",
          "endCaptures": { "0": { "name": "punctuation.definition.comment.aether" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aether",
          "begin": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.aether" } },
          "end": "\"",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.aether" } },
          "patterns": [
            {
              "name": "constant.character.escape.aether",
              "match": "\\\\([nrtv\\\\\"0abf]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4})"
            },
            {
              "name": "meta.interpolation.aether",
              "begin": "\\$\\{",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.aether" } },
              "end": "\\}",
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.aether" } },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.aether",
          "match": "\\b0[xX][0-9a-fA-F](?:[0-9a-fA-F_]*[0-9a-fA-F])?\\b"
        },
        {
          "name": "constant.numeric.binary.aether",
          "match": "\\b0[bB][01](?:[01_]*[01])?\\b"
        },
        {
          "name": "constant.numeric.octal.aether",
          "match": "\\b0[oO][0-7](?:[0-7_]*[0-7])?\\b"
        },
        {
          "name": "constant.numeric.float.aether",
          "match": "\\b\\d(?:[\\d_]*\\d)?\\.\\d(?:[\\d_]*\\d)?(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.decimal.aether",
          "match": "\\b\\d(?:[\\d_]*\\d)?\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.aether",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.aether",
          "match": "\\b(null)\\b"
        },
        {
          "name": "constant.language.aether",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "cons-pattern": {
      "comment": "Highlights the [head | tail] cons-cell pattern shape used by *StringSeq matches. Captures the brackets and the pipe so they pop in the same hue as keywords.",
      "patterns": [
        {
          "name": "meta.pattern.cons.aether",
          "match": "(\\[)\\s*([a-zA-Z_]\\w*|_)(?:\\s*,\\s*[a-zA-Z_]\\w*|_)*\\s*(\\|)\\s*([a-zA-Z_]\\w*|_)\\s*(\\])",
          "captures": {
            "1": { "name": "punctuation.section.brackets.begin.aether" },
            "2": { "name": "variable.other.aether" },
            "3": { "name": "punctuation.separator.cons.aether" },
            "4": { "name": "variable.other.aether" },
            "5": { "name": "punctuation.section.brackets.end.aether" }
          }
        }
      ]
    },
    "typed-pointer": {
      "comment": "*StructName syntax (PR #307) — render the struct name as a type. The leading * is treated as a type punctuation, not as multiplication.",
      "patterns": [
        {
          "match": "(\\*)([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.operator.type.pointer.aether" },
            "2": { "name": "entity.name.type.aether" }
          }
        }
      ]
    },
    "storage-keywords": {
      "comment": "Declarations and modifiers that introduce a new binding or affect visibility. Distinct from control flow so the editor can colour them blue while keeping flow words purple.",
      "patterns": [
        {
          "name": "storage.type.aether",
          "match": "\\b(actor|struct|message|state|extern|func|let|var|const|builder|callback)\\b"
        },
        {
          "name": "keyword.declaration.aether",
          "match": "\\b(import|export|as|hide|seal|except)\\b"
        }
      ]
    },
    "control-keywords": {
      "comment": "Statements that change control flow. Match → flow because match is the dispatch construct, not a binder.",
      "patterns": [
        {
          "name": "keyword.control.aether",
          "match": "\\b(if|else|for|while|switch|case|default|break|continue|return|match|receive|send|spawn_actor|spawn|defer|panic|try|catch|after)\\b"
        }
      ]
    },
    "primitive-types": {
      "patterns": [
        {
          "name": "support.type.primitive.aether",
          "match": "\\b(int|int64|int32|long|short|float|double|bool|string|void|ptr|actor_ref)\\b"
        }
      ]
    },
    "function-definitions": {
      "comment": "Aether function-definition shape: `name(params) -> ReturnType { … }` or `name(params) { … }`. The entity.name.function scope makes the name pop in yellow-cream.",
      "patterns": [
        {
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.aether" },
            "2": { "name": "entity.name.function.aether" }
          }
        },
        {
          "match": "^\\s*(main)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.main.aether" }
          }
        },
        {
          "comment": "Top-level Python-style typed function definition: `name(arg: T, …) -> R {`. Constrained to top-level (anchored) so it doesn't fight with call sites mid-expression.",
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\([^)]*\\)\\s*(?:->|\\{))",
          "captures": {
            "1": { "name": "entity.name.function.aether" }
          }
        }
      ]
    },
    "actor-definitions": {
      "patterns": [
        {
          "match": "\\b(actor)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.aether" },
            "2": { "name": "entity.name.actor.aether" }
          }
        }
      ]
    },
    "struct-definitions": {
      "patterns": [
        {
          "match": "\\b(struct)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.aether" },
            "2": { "name": "entity.name.struct.aether" }
          }
        }
      ]
    },
    "message-definitions": {
      "patterns": [
        {
          "match": "\\b(message)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.aether" },
            "2": { "name": "entity.name.message.aether" }
          }
        }
      ]
    },
    "qualified-calls": {
      "comment": "namespace.function(...) — string.split, string.seq_cons, intarr.get, etc. The namespace prefix renders like a variable; the call name like a function.",
      "patterns": [
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(\\.)\\s*([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "variable.other.aether" },
            "2": { "name": "punctuation.accessor.aether" },
            "3": { "name": "support.function.aether" }
          }
        }
      ]
    },
    "function-calls": {
      "comment": "Bare function calls (no namespace) inside expressions. Less aggressive than the previous grammar — only matches when the identifier is directly followed by `(`, and only when it's not already captured by a more specific rule above.",
      "patterns": [
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "support.function.aether" }
          }
        }
      ]
    },
    "operators": {
      "comment": "Order matters: longer literals first so `->` wins over `-`, `==` over `=`, etc. The pattern arrow gets its own scope so the theme can render it as the dispatch glyph it is rather than just another operator.",
      "patterns": [
        {
          "name": "keyword.operator.arrow.aether",
          "match": "->"
        },
        {
          "name": "keyword.operator.assignment.aether",
          "match": "(\\+=|-=|\\*=|/=|%=|<<=|>>=|&=|\\|=|\\^=|=)"
        },
        {
          "name": "keyword.operator.comparison.aether",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.aether",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.aether",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.aether",
          "match": "(<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.actor.aether",
          "match": "(!|\\?)"
        }
      ]
    }
  }
}

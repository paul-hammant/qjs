// Regression test: JSON Go-style wrapper error-path coverage.
// Each new wrapper (stringify, get_string, object_get, object_set,
// array_get, array_add) should return a non-empty error string when
// called with a wrong-type argument, and "" on the happy path.

import std.json

main() {
    print("=== JSON Wrapper Error Tuple Tests ===\n\n")

    // Prepare sample values of different types
    num, _  = json.parse("42")
    str, _  = json.parse("\"hello\"")
    arr, _  = json.parse("[1,2,3]")
    obj, _  = json.parse("{\"x\":10}")

    fails = 0

    // --- stringify ---
    print("stringify:\n")
    s_obj, se_obj = json.stringify(obj)
    if se_obj != "" { println("  FAIL: stringify valid obj: ${se_obj}"); fails = fails + 1 }
    else { println("  PASS: stringify object = '${s_obj}'") }

    // --- get_string ---
    print("\nget_string:\n")
    gs_num, gs_err_num = json.get_string(num)
    if gs_err_num == "" { println("  FAIL: get_string on number should error"); fails = fails + 1 }
    else { println("  PASS: get_string on number errored: ${gs_err_num}") }

    gs_str, gs_err_str = json.get_string(str)
    if gs_err_str != "" { println("  FAIL: get_string on string: ${gs_err_str}"); fails = fails + 1 }
    else if gs_str != "hello" { println("  FAIL: got '${gs_str}'"); fails = fails + 1 }
    else { print("  PASS: get_string on string returned 'hello'\n") }

    // --- object_get ---
    print("\nobject_get:\n")
    og_arr, og_err_arr = json.object_get(arr, "x")
    if og_err_arr == "" { println("  FAIL: object_get on array should error"); fails = fails + 1 }
    else { println("  PASS: object_get on array errored: ${og_err_arr}") }

    og_hit, og_err_hit = json.object_get(obj, "x")
    if og_err_hit != "" { println("  FAIL: object_get present key: ${og_err_hit}"); fails = fails + 1 }
    else if og_hit == null { println("  FAIL: got null for present key"); fails = fails + 1 }
    else { print("  PASS: object_get present key\n") }

    og_miss, og_err_miss = json.object_get(obj, "missing_key")
    if og_err_miss != "" { println("  FAIL: absent key should be (null, ''): ${og_err_miss}"); fails = fails + 1 }
    else if og_miss != null { println("  FAIL: expected null for absent key"); fails = fails + 1 }
    else { print("  PASS: object_get absent key returns (null, '')\n") }

    // --- object_set ---
    print("\nobject_set:\n")
    os_err_arr = json.object_set(arr, "k", json.create_null())
    if os_err_arr == "" { println("  FAIL: object_set on array should error"); fails = fails + 1 }
    else { println("  PASS: object_set on array errored: ${os_err_arr}") }

    os_ok = json.object_set(obj, "y", json.create_number(20.0))
    if os_ok != "" { println("  FAIL: object_set on obj: ${os_ok}"); fails = fails + 1 }
    else { print("  PASS: object_set on object ok\n") }

    // --- array_get ---
    print("\narray_get:\n")
    ag_obj, ag_err_obj = json.array_get(obj, 0)
    if ag_err_obj == "" { println("  FAIL: array_get on object should error"); fails = fails + 1 }
    else { println("  PASS: array_get on object errored: ${ag_err_obj}") }

    ag_hit, ag_err_hit = json.array_get(arr, 1)
    if ag_err_hit != "" { println("  FAIL: array_get in range: ${ag_err_hit}"); fails = fails + 1 }
    else if json.get_int(ag_hit) != 2 { println("  FAIL: got ${json.get_int(ag_hit)}"); fails = fails + 1 }
    else { print("  PASS: array_get[1] == 2\n") }

    ag_oob, ag_err_oob = json.array_get(arr, 99)
    if ag_err_oob != "" { println("  FAIL: oob should be (null, ''): ${ag_err_oob}"); fails = fails + 1 }
    else if ag_oob != null { println("  FAIL: expected null for oob"); fails = fails + 1 }
    else { print("  PASS: array_get oob returns (null, '')\n") }

    // --- array_add ---
    print("\narray_add:\n")
    aa_err_obj = json.array_add(obj, json.create_number(1.0))
    if aa_err_obj == "" { println("  FAIL: array_add on object should error"); fails = fails + 1 }
    else { println("  PASS: array_add on object errored: ${aa_err_obj}") }

    aa_ok = json.array_add(arr, json.create_number(99.0))
    if aa_ok != "" { println("  FAIL: array_add on arr: ${aa_ok}"); fails = fails + 1 }
    else if json.array_size(arr) != 4 { println("  FAIL: size ${json.array_size(arr)}"); fails = fails + 1 }
    else { print("  PASS: array_add on array ok, size=4\n") }

    json.free(num)
    json.free(str)
    json.free(arr)
    json.free(obj)

    if fails > 0 {
        println("\n=== ${fails} test(s) failed ===")
        exit(1)
    }
    print("\n=== All Error Tuple Tests Passed ===\n")
}

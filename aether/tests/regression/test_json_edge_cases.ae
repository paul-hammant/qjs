// Regression test: JSON parser edge cases (escape handling, type checking,
// nested structures, tuple-wrapper error paths).
//
// Uses the Go-style wrappers from std.json: every fallible call returns
// (value, err) or just err. The typed getters (get_bool/get_number/get_int)
// remain infallible-with-sentinel.

import std.json
import std.string

main() {
    print("=== JSON Edge Case Tests ===\n\n")

    // Test 1: escaped newline
    print("Test 1: JSON escaped characters\n")
    j1, _ = json.parse("{\"msg\":\"hello\\nworld\"}")
    m1, _ = json.object_get(j1, "msg")
    s1, _ = json.get_string(m1)
    if string.length(s1) == 11 {
        print("  PASS: escaped newline parsed (length 11)\n")
    } else {
        print("  FAIL: length = ")
        print(string.length(s1))
        print("\n")
        exit(1)
    }
    json.free(j1)

    // Test 2: escaped tab
    print("\nTest 2: JSON escaped tab\n")
    j2, _ = json.parse("{\"t\":\"a\\tb\"}")
    m2, _ = json.object_get(j2, "t")
    s2, _ = json.get_string(m2)
    if string.length(s2) == 3 {
        print("  PASS: escaped tab parsed (length 3)\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j2)

    // Test 3: escaped quote in string
    print("\nTest 3: JSON escaped quote\n")
    j3, _ = json.parse("{\"q\":\"he said \\\"hi\\\"\"}")
    m3, _ = json.object_get(j3, "q")
    s3, _ = json.get_string(m3)
    if string.length(s3) == 12 {
        print("  PASS: escaped quotes parsed\n")
    } else {
        print("  FAIL: length = ")
        print(string.length(s3))
        print("\n")
        exit(1)
    }
    json.free(j3)

    // Test 4: escaped backslash
    print("\nTest 4: JSON escaped backslash\n")
    j4, _ = json.parse("{\"p\":\"C:\\\\Users\"}")
    m4, _ = json.object_get(j4, "p")
    s4, _ = json.get_string(m4)
    if s4 == "C:\\Users" {
        print("  PASS: escaped backslash parsed\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j4)

    // Test 5: escaped forward slash
    print("\nTest 5: JSON escaped forward slash\n")
    j5, _ = json.parse("{\"url\":\"http:\\/\\/example.com\"}")
    m5, _ = json.object_get(j5, "url")
    s5, _ = json.get_string(m5)
    if s5 == "http://example.com" {
        print("  PASS: escaped slash parsed\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j5)

    // Test 6: boolean values
    print("\nTest 6: JSON booleans\n")
    j6, _ = json.parse("{\"a\":true,\"b\":false}")
    a_val, _ = json.object_get(j6, "a")
    b_val, _ = json.object_get(j6, "b")
    if json.get_bool(a_val) == 1 {
        if json.get_bool(b_val) == 0 {
            print("  PASS: true=1, false=0\n")
        } else {
            print("  FAIL: false != 0\n")
            exit(1)
        }
    } else {
        print("  FAIL: true != 1\n")
        exit(1)
    }
    json.free(j6)

    // Test 7: negative number
    print("\nTest 7: JSON negative number\n")
    j7, _ = json.parse("-42")
    if json.get_int(j7) == 0 - 42 {
        print("  PASS: -42 parsed\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j7)

    // Test 8: float number
    print("\nTest 8: JSON float\n")
    j8, _ = json.parse("3.14")
    if json.type(j8) == 2 {
        print("  PASS: 3.14 is number type\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j8)

    // Test 9: mixed-type array
    print("\nTest 9: mixed-type array\n")
    j9, _ = json.parse("[1,\"two\",true,null]")
    if json.array_size(j9) == 4 {
        e0, _ = json.array_get(j9, 0)
        e1, _ = json.array_get(j9, 1)
        e2, _ = json.array_get(j9, 2)
        e3, _ = json.array_get(j9, 3)
        if json.type(e0) == 2 {
            if json.type(e1) == 3 {
                if json.type(e2) == 1 {
                    if json.is_null(e3) == 1 {
                        print("  PASS: [number, string, bool, null]\n")
                    } else {
                        print("  FAIL: e3 not null\n")
                        exit(1)
                    }
                } else {
                    print("  FAIL: e2 not bool\n")
                    exit(1)
                }
            } else {
                print("  FAIL: e1 not string\n")
                exit(1)
            }
        } else {
            print("  FAIL: e0 not number\n")
            exit(1)
        }
    } else {
        print("  FAIL: array size\n")
        exit(1)
    }
    json.free(j9)

    // Test 10: json.get_bool on non-bool returns sentinel 0
    print("\nTest 10: get_bool on string returns 0\n")
    j10, _ = json.parse("\"text\"")
    if json.get_bool(j10) == 0 {
        print("  PASS: get_bool on string = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j10)

    // Test 11: json.get_int on non-number returns sentinel 0
    print("\nTest 11: get_int on string returns 0\n")
    j11, _ = json.parse("\"text\"")
    if json.get_int(j11) == 0 {
        print("  PASS: get_int on string = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j11)

    // Test 12: stringify round-trip
    print("\nTest 12: stringify round-trip\n")
    j12, _ = json.parse("{\"x\":1,\"y\":\"hello\"}")
    s12, _ = json.stringify(j12)
    j12b, _ = json.parse(s12)
    xv, _ = json.object_get(j12b, "x")
    yv, _ = json.object_get(j12b, "y")
    ys, _ = json.get_string(yv)
    if json.get_int(xv) == 1 {
        if ys == "hello" {
            print("  PASS: round-trip preserves values\n")
        } else {
            print("  FAIL: y != hello\n")
            exit(1)
        }
    } else {
        print("  FAIL: x != 1\n")
        exit(1)
    }
    json.free(j12)
    json.free(j12b)

    // Test 13: 4-level nested array
    print("\nTest 13: moderately nested JSON\n")
    j13, _ = json.parse("[[[[1]]]]")
    if json.type(j13) == 4 {
        lvl1, _ = json.array_get(j13, 0)
        lvl2, _ = json.array_get(lvl1, 0)
        lvl3, _ = json.array_get(lvl2, 0)
        leaf, _ = json.array_get(lvl3, 0)
        if json.get_int(leaf) == 1 {
            print("  PASS: 4-level nested array\n")
        } else {
            print("  FAIL: inner value\n")
            exit(1)
        }
    } else {
        print("  FAIL: not array\n")
        exit(1)
    }
    json.free(j13)

    // Test 14: empty string value
    print("\nTest 14: empty string in JSON\n")
    j14, _ = json.parse("{\"empty\":\"\"}")
    ev, _ = json.object_get(j14, "empty")
    s14, _ = json.get_string(ev)
    if s14 == "" {
        print("  PASS: empty string value\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j14)

    // Test 15: array_get out of bounds now returns (null, "")
    print("\nTest 15: array_get out of bounds\n")
    j15, _ = json.parse("[1,2]")
    oob, oob_err = json.array_get(j15, 99)
    if oob == null {
        if oob_err == "" {
            print("  PASS: out of bounds returns (null, empty error)\n")
        } else {
            println("  FAIL: expected empty err, got: ${oob_err}")
            exit(1)
        }
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j15)

    // Test 16: create and stringify empty object
    print("\nTest 16: create + stringify empty object\n")
    obj16 = json.create_object()
    s16, _ = json.stringify(obj16)
    if s16 == "{}" {
        print("  PASS: empty object stringifies to {}\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(obj16)

    // Test 17: create and stringify empty array
    print("\nTest 17: create + stringify empty array\n")
    arr17 = json.create_array()
    s17, _ = json.stringify(arr17)
    if s17 == "[]" {
        print("  PASS: empty array stringifies to []\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(arr17)

    // Test 18: \b and \f escapes (new in stdlib-consistency pass)
    print("\nTest 18: \\b and \\f escapes\n")
    j18, _ = json.parse("\"\\b\\f\"")
    s18, _ = json.get_string(j18)
    if string.length(s18) == 2 {
        print("  PASS: \\b\\f decoded (2 bytes)\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(j18)

    // Test 19: wrong-type access via wrapper reports error
    print("\nTest 19: object_get on non-object returns error\n")
    j19, _ = json.parse("[1,2,3]")
    _, og_err = json.object_get(j19, "key")
    if og_err == "" {
        print("  FAIL: expected error\n")
        exit(1)
    } else {
        print("  PASS: object_get on array errored\n")
    }
    json.free(j19)

    // Test 20: object_set on non-object returns error
    print("\nTest 20: object_set on non-object returns error\n")
    j20, _ = json.parse("[1,2,3]")
    os_err = json.object_set(j20, "k", json.create_null())
    if os_err == "" {
        print("  FAIL: expected error\n")
        exit(1)
    } else {
        print("  PASS: object_set on array errored\n")
    }
    json.free(j20)

    print("\n=== All JSON Edge Case Tests Passed ===\n")
}

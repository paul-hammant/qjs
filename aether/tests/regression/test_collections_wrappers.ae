// Regression test: collections Go-style wrapper error paths.
// Added during the stdlib-consistency pass alongside the rename of
// list_get/map_get/map_keys → *_raw and the addition of `list.get`,
// `map.get`, `map.keys` wrappers.

import std.list
import std.map
import std.string

main() {
    print("=== Collections Wrapper Tests ===\n\n")

    fails = 0

    // --- list.get ---
    print("list.get:\n")
    l = list.new()
    defer list.free(l)
    _ = list.add(l, 10)
    _ = list.add(l, 20)

    // In-range
    v0, e0 = list.get(l, 0)
    if e0 != "" { println("  FAIL: in-range error: ${e0}"); fails = fails + 1 }
    else if v0 != 10 { println("  FAIL: wrong value ${v0}"); fails = fails + 1 }
    else { print("  PASS: in-range returns (value, '')\n") }

    // Out of range -> (null, "")
    vo, eo = list.get(l, 99)
    if vo != null { println("  FAIL: oob should be null"); fails = fails + 1 }
    else if eo != "" { println("  FAIL: oob should have empty err: ${eo}"); fails = fails + 1 }
    else { print("  PASS: oob returns (null, '')\n") }

    // Null list -> (null, "null list")
    vn, en = list.get(null, 0)
    if vn != null { println("  FAIL: null list should be null"); fails = fails + 1 }
    else if en == "" { println("  FAIL: null list should have error"); fails = fails + 1 }
    else { println("  PASS: null list returns (null, '${en}')") }

    // --- map.get ---
    print("\nmap.get:\n")
    m = map.new()
    defer map.free(m)
    s1 = string.new("hello")
    _ = map.put(m, "key1", s1)

    // Present
    gp, ep = map.get(m, "key1")
    if ep != "" { println("  FAIL: present key error: ${ep}"); fails = fails + 1 }
    else if gp == null { println("  FAIL: present key null"); fails = fails + 1 }
    else { print("  PASS: present key returns (value, '')\n") }

    // Absent -> (null, "")
    ga, ea = map.get(m, "missing")
    if ga != null { println("  FAIL: absent key should be null"); fails = fails + 1 }
    else if ea != "" { println("  FAIL: absent err non-empty: ${ea}"); fails = fails + 1 }
    else { print("  PASS: absent key returns (null, '')\n") }

    // Null map -> (null, "null map")
    gn, en2 = map.get(null, "any")
    if gn != null { println("  FAIL: null map should be null"); fails = fails + 1 }
    else if en2 == "" { println("  FAIL: null map should have error"); fails = fails + 1 }
    else { println("  PASS: null map returns (null, '${en2}')") }

    string.release(s1)

    // --- map.keys ---
    print("\nmap.keys:\n")
    m2 = map.new()
    defer map.free(m2)
    s2 = string.new("v1")
    s3 = string.new("v2")
    _ = map.put(m2, "a", s2)
    _ = map.put(m2, "b", s3)

    k, ke = map.keys(m2)
    if ke != "" { println("  FAIL: keys error: ${ke}"); fails = fails + 1 }
    else if k == null { println("  FAIL: keys null"); fails = fails + 1 }
    else { print("  PASS: keys returns (snapshot, '')\n") }

    if k != null { map.keys_free(k) }

    kn, kne = map.keys(null)
    if kn != null { println("  FAIL: null map keys should be null"); fails = fails + 1 }
    else if kne == "" { println("  FAIL: null map keys should error"); fails = fails + 1 }
    else { println("  PASS: null map keys returns (null, '${kne}')") }

    string.release(s2)
    string.release(s3)

    if fails > 0 {
        println("\n=== ${fails} test(s) failed ===")
        exit(1)
    }
    print("\n=== All Collections Wrapper Tests Passed ===\n")
}

// Regression test for #287 — same-file callers can resolve
// `export`-tagged sibling functions.
//
// Pre-fix the typechecker's first pass walked program->children
// switching on child->type, but `export X(...)` wraps the function
// definition in AST_EXPORT_STATEMENT. Without an explicit case
// handling that wrapper, the inner function never got registered in
// the symbol table — same-file callers got "Undefined function 'X'".
//
// Three shapes covered:
//   1. export → export — both sides exported, the caller is one
//      exported function calling another.
//   2. non-export → export — a private helper calling an exported
//      sibling.
//   3. The unwrap pass also registers the function correctly so the
//      OUTSIDE-the-module qualified-call path (via std.X.foo) can
//      still find it. Verified indirectly by main() invoking the
//      exports — if the unwrap had broken qualified resolution,
//      main couldn't reach them either.

import std.string

extern exit(code: int)

export probe(s: string) -> int {
    if string.length(s) > 0 { return 1 }
    return 0
}

export use_probe_export(s: string) -> int {
    // Case 1: export → export same-file call.
    return probe(s)
}

helper_priv(s: string) -> int {
    // Case 2: non-export → export same-file call.
    return probe(s)
}

main() {
    // Case 1
    a = use_probe_export("hello")
    if a != 1 {
        println("FAIL case 1: use_probe_export returned ${a}, want 1")
        exit(1)
    }

    // Case 2
    b = helper_priv("hello")
    if b != 1 {
        println("FAIL case 2: helper_priv returned ${b}, want 1")
        exit(1)
    }

    // Case 3 — empty string → 0
    c = use_probe_export("")
    if c != 0 {
        println("FAIL case 3: use_probe_export(\"\") returned ${c}, want 0")
        exit(1)
    }

    println("OK")
}

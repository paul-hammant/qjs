// Regression test: std.io edge cases
// Covers: file read/write, non-existent files, empty files, getenv.
// Uses the Go-style wrappers: read_file/write_file/append_file/delete_file
// all return `(value, err)` or `err`.

import std.io

main() {
    print("=== IO Edge Case Tests ===\n\n")

    tmp = io.getenv("TEMP")
    if tmp == 0 {
        tmp = io.getenv("TMPDIR")
    }
    if tmp == 0 {
        tmp = "/tmp"
    }

    // Test 1: read non-existent file returns error.
    print("Test 1: read non-existent file\n")
    _, e1 = io.read_file("${tmp}/aether_nonexistent_xyz_987")
    if e1 != "" {
        print("  PASS: read_file returns error for missing file\n")
    } else {
        print("  FAIL: expected error\n")
        exit(1)
    }

    // Test 2: write + read round-trip
    print("\nTest 2: write + read round-trip\n")
    test_path = "${tmp}/aether_io_test.txt"
    we = io.write_file(test_path, "hello io")
    if we != "" { println("  FAIL: write: ${we}"); exit(1) }
    content2, re2 = io.read_file(test_path)
    if re2 != "" { println("  FAIL: read: ${re2}"); exit(1) }
    if content2 == "hello io" {
        print("  PASS: write + read round-trip\n")
    } else {
        print("  FAIL: content mismatch\n")
        exit(1)
    }

    // Test 3: append
    print("\nTest 3: append to file\n")
    ae3 = io.append_file(test_path, " world")
    if ae3 != "" { println("  FAIL: append: ${ae3}"); exit(1) }
    content3, _ = io.read_file(test_path)
    if content3 == "hello io world" {
        print("  PASS: append works\n")
    } else {
        print("  FAIL: content mismatch\n")
        exit(1)
    }

    // Test 4: file_exists (bare extern — still int)
    print("\nTest 4: file_exists\n")
    if io.file_exists(test_path) == 1 {
        print("  PASS: file exists after write\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 5: delete
    print("\nTest 5: delete file\n")
    de5 = io.delete_file(test_path)
    if de5 != "" { println("  FAIL: delete: ${de5}"); exit(1) }
    if io.file_exists(test_path) == 0 {
        print("  PASS: file deleted\n")
    } else {
        print("  FAIL: file still exists\n")
        exit(1)
    }

    // Test 6: delete non-existent file returns error.
    print("\nTest 6: delete non-existent file\n")
    de6 = io.delete_file("${tmp}/aether_nonexistent_xyz_987")
    if de6 != "" {
        print("  PASS: delete non-existent returns error\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 7: write empty content
    print("\nTest 7: write empty content\n")
    test_path2 = "${tmp}/aether_io_empty_test.txt"
    we7 = io.write_file(test_path2, "")
    if we7 != "" { println("  FAIL: write: ${we7}"); exit(1) }
    content4, _ = io.read_file(test_path2)
    if content4 == "" {
        print("  PASS: empty file write + read\n")
    } else {
        print("  FAIL: content not empty\n")
        exit(1)
    }
    _ = io.delete_file(test_path2)

    // Test 8: getenv on known variable (bare extern — stays string)
    print("\nTest 8: getenv PATH\n")
    path_val = io.getenv("PATH")
    if path_val != 0 {
        print("  PASS: PATH is set\n")
    } else {
        print("  FAIL: PATH not found\n")
        exit(1)
    }

    // Test 9: getenv on unknown variable returns null.
    print("\nTest 9: getenv unknown\n")
    unknown = io.getenv("AETHER_NONEXISTENT_VAR_XYZ")
    if unknown == 0 {
        print("  PASS: unknown var returns NULL\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 10: file_info on non-existent returns error.
    print("\nTest 10: file_info on non-existent\n")
    info, ierr = io.file_info("${tmp}/aether_nonexistent_xyz_987")
    if ierr != "" {
        print("  PASS: file_info returns error for missing file\n")
    } else {
        io.file_info_free(info)
        print("  FAIL\n")
        exit(1)
    }

    print("\n=== All IO Edge Case Tests Passed ===\n")
}

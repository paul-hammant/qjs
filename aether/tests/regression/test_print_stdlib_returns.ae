// Regression test: printing stdlib return values without garbage.
// Covers string/tuple handling in print and interpolation after the
// Go-style wrapper migration — the values come back as Aether strings
// (not raw C pointers), so they must print and interpolate cleanly.

import std.file
import std.io

main() {
    println("=== Print Stdlib Returns ===")

    // Relative paths: cwd is writable on every CI row we target,
    // whereas /tmp only works on POSIX. Cleanup at the end of main()
    // removes both files before we exit.
    test_path = "_aether_regression_print.txt"

    // Setup: write a known file via the convenience wrapper.
    we = file.write(test_path, "test-content")
    if we != "" { println("setup FAIL: ${we}"); exit(1) }

    // Test 1: print(file.read) result
    content, re = file.read(test_path)
    if re != "" { println("read FAIL: ${re}"); exit(1) }
    print("T1: ")
    print(content)
    print("\n")

    // Test 2: println
    print("T2: ")
    println(content)

    // Test 3: string interpolation with file content
    println("T3: ${content}")

    // Test 4: io.read_file + print
    io_content, _ = io.read_file(test_path)
    print("T4: ")
    println(io_content)

    // Test 5: io.read_file + interpolation
    println("T5: ${io_content}")

    // Test 6: io.getenv + print (bare extern, still returns string).
    // PATH is the one env var guaranteed to be set on every CI row we
    // target — HOME is POSIX-only, USERPROFILE is Windows-only.
    path_env = io.getenv("PATH")
    print("T6: PATH-present=")
    if path_env != "" { println("yes") } else { println("no") }

    // Test 7: io.getenv + interpolation (just prove the string survives
    // interpolation; don't dump the whole PATH into the log).
    path_present = "no"
    if path_env != "" { path_present = "yes" }
    println("T7: ${path_present}")

    // Test 8: mixed types in interpolation
    x = 42
    pi = 3.14
    println("T8: x=${x} pi=${pi} content=${content}")

    // Test 9: file.exists (int) + file.size (tuple).
    exists = file.exists(test_path)
    size, _ = file.size(test_path)
    println("T9: exists=${exists} size=${size}")

    // Test 10: write + read roundtrip with different content
    test_path2 = "_aether_regression_print2.txt"
    _ = file.write(test_path2, "ABCDEF")
    rt, _ = file.read(test_path2)
    println("T10: ${rt}")

    // Cleanup
    _ = file.delete(test_path)
    _ = file.delete(test_path2)

    println("=== Done ===")
}

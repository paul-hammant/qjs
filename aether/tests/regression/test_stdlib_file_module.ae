// Regression test for GitHub issue #61 (stdlib module resolution) and
// the std.file Go-style wrappers. Updated after the stdlib consistency
// pass that migrated file.* to `(value, err)` / `err` return shapes.

import std.string
import std.math
import std.file

main() {
    println("=== Issue #61: stdlib resolution + std.file ===")

    s = string.new("aether")
    defer string.release(s)

    if string.length(s) != 6 {
        print("FAIL: string.length expected 6, got ")
        println(string.length(s))
        exit(1)
    }
    println("PASS: std.string imported and works")

    v = math.abs_int(-42)
    if v != 42 {
        print("FAIL: math.abs_int(-42) expected 42, got ")
        println(v)
        exit(1)
    }
    println("PASS: std.math imported and works")

    sq = math.sqrt(16.0)
    if sq < 3.99 {
        println("FAIL: math.sqrt(16.0) too low")
        exit(1)
    }
    if sq > 4.01 {
        println("FAIL: math.sqrt(16.0) too high")
        exit(1)
    }
    println("PASS: math.sqrt works")

    // file.write(path, content) is the new convenience form.
    we = file.write("_test_issue61_tmp.txt", "hello")
    if we != "" {
        println("FAIL: file.write: ${we}")
        exit(1)
    }

    if file.exists("_test_issue61_tmp.txt") == 0 {
        println("FAIL: file.exists returned 0 after write")
        exit(1)
    }
    println("PASS: file.write + file.exists work")

    sz, se = file.size("_test_issue61_tmp.txt")
    if se != "" {
        println("FAIL: file.size: ${se}")
        exit(1)
    }
    if sz != 5 {
        print("FAIL: file.size expected 5, got ")
        println(sz)
        exit(1)
    }
    println("PASS: file.size works")

    // file.read(path) reads whole file in one shot.
    _ = file.write("_test_issue61_tmp.txt", "Hello!")
    content, re = file.read("_test_issue61_tmp.txt")
    if re != "" {
        println("FAIL: file.read: ${re}")
        exit(1)
    }
    if content == 0 {
        println("FAIL: file.read returned null")
        exit(1)
    }
    println("PASS: file.read works")

    de = file.delete("_test_issue61_tmp.txt")
    if de != "" {
        println("FAIL: file.delete: ${de}")
        exit(1)
    }
    if file.exists("_test_issue61_tmp.txt") != 0 {
        println("FAIL: file still exists after delete")
        exit(1)
    }
    println("PASS: file.delete works")

    println("=== Issue #61: ALL PASS ===")
}

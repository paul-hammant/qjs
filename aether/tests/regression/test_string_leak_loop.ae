// Regression: string.concat in a loop leaks memory (OOM).
// Each iteration allocates a new string but must release the old one.
//
// Before fix: O(n^2) leaked memory, OOM on large inputs.
// After fix:  O(n) memory, constant RSS.

import std.string

main() {
    // Phase 1: string.concat in a tight loop.
    s = ""
    i = 0
    while i < 100000 {
        s = string.concat(s, "x")
        i = i + 1
    }
    println("concat loop done, length = ${string.length(s)}")

    // Phase 2: simulated replace-all using index_of + substring + concat.
    input = "hello.world.foo.bar.baz"
    result = input
    j = 0
    while j < 1000 {
        out = ""
        tmp = result
        idx = string.index_of(tmp, ".")
        while idx >= 0 {
            out = string.concat(out, string.substring(tmp, 0, idx))
            out = string.concat(out, "/")
            tmp = string.substring(tmp, idx + 1, string.length(tmp))
            idx = string.index_of(tmp, ".")
        }
        out = string.concat(out, tmp)
        result = out
        j = j + 1
    }
    println("replace-all loop done")
    println(result)
}

// Regression test for #288 — std.bytes mutable byte buffer.
//
// The headline use case is RLE-style overlap copy, where the output
// buffer is read at offsets that the same call has just written.
// memmove() handles overlap by choosing the safe direction; that
// would defeat the purpose. std.bytes.copy_within is forward-byte-
// by-byte deliberately.
//
// Cases:
//   1. new + set + length + finish — basic single-byte writes,
//      logical length tracks the highest-touched index + 1.
//   2. set with a gap — bytes between the previous tail and the new
//      index zero-fill.
//   3. copy_from_string — reads from an Aether string into the
//      buffer at an offset.
//   4. copy_within RLE expansion — the canonical pattern.
//   5. copy_within non-overlapping — dst <= src, full source must
//      already exist; fails if it doesn't.
//   6. free without finish — discard path.

import std.bytes
import std.string

extern exit(code: int)

main() {
    println("=== std.bytes regression ===")

    // Case 1: new + set + length + finish
    b1 = bytes.new(4)
    bytes.set(b1, 0, 72)   // 'H'
    bytes.set(b1, 1, 105)  // 'i'
    if bytes.length(b1) != 2 {
        println("  FAIL 1: length=${bytes.length(b1)}, expected 2")
        exit(1)
    }
    out1 = bytes.finish(b1, 2)
    if out1 != "Hi" {
        println("  FAIL 1: got '${out1}', expected 'Hi'")
        exit(1)
    }
    println("  PASS: new + set + finish")

    // Case 2: set with a gap zero-fills.
    b2 = bytes.new(0)
    bytes.set(b2, 0, 65)   // 'A'
    bytes.set(b2, 4, 90)   // 'Z' at index 4 — bytes 1..3 stay zero
    n2 = bytes.length(b2)
    if n2 != 5 {
        println("  FAIL 2: length=${n2}, expected 5")
        exit(1)
    }
    bytes.free(b2)  // discard — we only wanted to confirm the length
    println("  PASS: set with gap zero-fills, length tracks highest write")

    // Case 3: copy_from_string at an offset.
    b3 = bytes.new(0)
    bytes.set(b3, 0, 91)   // '['
    bytes.copy_from_string(b3, 1, "abc", 3)
    bytes.set(b3, 4, 93)   // ']'
    out3 = bytes.finish(b3, 5)
    if out3 != "[abc]" {
        println("  FAIL 3: got '${out3}', expected '[abc]'")
        exit(1)
    }
    println("  PASS: copy_from_string at offset")

    // Case 4: copy_within RLE expansion.
    // Pre-fill [A, B], then copy_within(dst=2, src=0, length=4).
    // The forward-byte-by-byte loop reads byte 2 (just written 'A'),
    // then byte 3 (just written 'B'), giving [A,B,A,B,A,B].
    b4 = bytes.new(8)
    bytes.set(b4, 0, 65)   // 'A'
    bytes.set(b4, 1, 66)   // 'B'
    bytes.copy_within(b4, 2, 0, 4)
    out4 = bytes.finish(b4, 6)
    if out4 != "ABABAB" {
        println("  FAIL 4: got '${out4}', expected 'ABABAB' (RLE overlap)")
        exit(1)
    }
    println("  PASS: copy_within RLE expansion (the headline case)")

    // Case 5: copy_within non-overlapping where dst <= src — the full
    // source range must already exist.
    b5 = bytes.new(8)
    bytes.set(b5, 0, 88)   // 'X'
    bytes.set(b5, 1, 89)   // 'Y'
    bytes.set(b5, 2, 90)   // 'Z'
    // dst=0, src=1, length=2 — copies "YZ" over "XY".
    bytes.copy_within(b5, 0, 1, 2)
    out5 = bytes.finish(b5, 3)
    if out5 != "YZZ" {
        println("  FAIL 5: got '${out5}', expected 'YZZ'")
        exit(1)
    }
    println("  PASS: copy_within with dst<=src (non-overlap shape)")

    // Case 6: free without finish — the discard path. Just exercise
    // it; we have no observable side effect to check beyond no crash.
    b6 = bytes.new(64)
    bytes.set(b6, 0, 33)
    bytes.free(b6)
    println("  PASS: free without finish")

    println("=== All cases passed ===")
}

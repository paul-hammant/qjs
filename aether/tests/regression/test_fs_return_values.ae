// Regression test: file and directory operation return values.
// Covers the Go-style `(value, err)` / `err` return shape used by
// std.file and std.dir wrappers. Original version of this test
// predated the Go-style migration; now updated to match the
// canonical pattern documented in docs/stdlib-module-pattern.md.

import std.file
import std.dir
import std.io

main() {
    println("=== FS Return Value Tests ===")

    tmp = io.getenv("TEMP")
    if tmp == 0 {
        tmp = io.getenv("TMPDIR")
    }
    if tmp == 0 {
        tmp = "/tmp"
    }

    // Test 1: file.delete on non-existent file returns a non-empty error.
    println("\nTest 1: file.delete non-existent returns error")
    e1 = file.delete("${tmp}/aether_fs_test_nonexistent_xyz")
    if e1 != "" {
        println("  PASS: ${e1}")
    } else {
        println("  FAIL: expected error, got empty")
        exit(1)
    }

    // Test 2: file.write on a fresh path returns "" on success.
    println("\nTest 2: file.write returns empty err on success")
    e2 = file.write("${tmp}/aether_fs_write_test.txt", "test data")
    if e2 == "" {
        println("  PASS")
    } else {
        println("  FAIL: ${e2}")
        exit(1)
    }

    // Test 3: file.delete on existing file returns "" (success).
    println("\nTest 3: file.delete existing file returns empty err")
    e3 = file.delete("${tmp}/aether_fs_write_test.txt")
    if e3 == "" {
        println("  PASS")
    } else {
        println("  FAIL: ${e3}")
        exit(1)
    }

    // Test 4: file.delete same file again returns error.
    println("\nTest 4: file.delete already-deleted returns error")
    e4 = file.delete("${tmp}/aether_fs_write_test.txt")
    if e4 != "" {
        println("  PASS: ${e4}")
    } else {
        println("  FAIL: expected error")
        exit(1)
    }

    // Test 5: dir.exists on non-existent directory returns 0 (bare extern).
    println("\nTest 5: dir.exists non-existent returns 0")
    if dir.exists("${tmp}/aether_fs_test_nonexistent_dir_xyz") == 0 {
        println("  PASS")
    } else {
        println("  FAIL")
        exit(1)
    }

    // Test 6: dir.create on fresh path returns "" on success.
    println("\nTest 6: dir.create returns empty err on success")
    de6 = dir.create("${tmp}/aether_fs_test_dir")
    if de6 == "" {
        println("  PASS")
    } else {
        println("  FAIL: ${de6}")
        exit(1)
    }

    // Test 7: dir.exists on existing directory returns 1.
    println("\nTest 7: dir.exists on existing directory returns 1")
    if dir.exists("${tmp}/aether_fs_test_dir") == 1 {
        println("  PASS")
    } else {
        println("  FAIL")
        exit(1)
    }

    // Test 8: dir.create on already-existing returns error.
    println("\nTest 8: dir.create duplicate returns error")
    de8 = dir.create("${tmp}/aether_fs_test_dir")
    if de8 != "" {
        println("  PASS: ${de8}")
    } else {
        println("  FAIL: expected error")
        exit(1)
    }

    // Test 9: dir.delete on existing returns "".
    println("\nTest 9: dir.delete existing returns empty err")
    de9 = dir.delete("${tmp}/aether_fs_test_dir")
    if de9 == "" {
        println("  PASS")
    } else {
        println("  FAIL: ${de9}")
        exit(1)
    }

    // Test 10: dir.exists after delete returns 0.
    println("\nTest 10: dir.exists after delete returns 0")
    if dir.exists("${tmp}/aether_fs_test_dir") == 0 {
        println("  PASS")
    } else {
        println("  FAIL")
        exit(1)
    }

    // Test 11: file.exists on a directory returns 0 (distinct from dir.exists).
    println("\nTest 11: file.exists on directory returns 0")
    _ = dir.create("${tmp}/aether_fs_test_dir2")
    if file.exists("${tmp}/aether_fs_test_dir2") == 0 {
        println("  PASS: file.exists correctly rejects directory")
    } else {
        println("  FAIL: file.exists should return 0 for directories")
        exit(1)
    }
    _ = dir.delete("${tmp}/aether_fs_test_dir2")

    println("\n=== All FS Return Value Tests Passed ===")
}

// Regression test: stdlib edge cases across all modules
// Tests for bugs found in audit: type mismatches, bounds issues, etc.

import std.string
import std.fs
import std.file
import std.path
import std.json
import std.io

main() {
    print("=== Stdlib Edge Case Tests ===\n\n")

    // Use platform temp dir
    tmp = io.getenv("TEMP")
    if tmp == 0 {
        tmp = io.getenv("TMPDIR")
    }
    if tmp == 0 {
        tmp = "/tmp"
    }

    // === PATH MODULE: return types should be string, not ptr ===
    print("Test 1: path.join returns usable string\n")
    joined = path.join("/tmp", "test.txt")
    if joined == "/tmp/test.txt" {
        print("  PASS: path.join returns string\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\nTest 2: path.dirname returns usable string\n")
    dir = path.dirname("/tmp/test.txt")
    if dir == "/tmp" {
        print("  PASS: path.dirname returns string\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\nTest 3: path.basename returns usable string\n")
    base = path.basename("/tmp/test.txt")
    if base == "test.txt" {
        print("  PASS: path.basename returns string\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\nTest 4: path.extension returns usable string\n")
    ext = path.extension("/tmp/test.txt")
    if ext == ".txt" {
        print("  PASS: path.extension returns string\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // === PATH EDGE CASES ===
    print("\nTest 5: path.is_absolute with short strings\n")
    r1 = path.is_absolute("")
    if r1 == 0 {
        print("  PASS: empty string not absolute\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    r2 = path.is_absolute("/")
    if r2 == 1 {
        print("  PASS: '/' is absolute\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    r3 = path.is_absolute("relative")
    if r3 == 0 {
        print("  PASS: 'relative' not absolute\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // === PATH with empty components ===
    print("\nTest 6: path.dirname of bare filename\n")
    dir2 = path.dirname("file.txt")
    if dir2 == "." {
        print("  PASS: dirname('file.txt') = '.'\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\nTest 7: path.extension with no extension\n")
    ext2 = path.extension("Makefile")
    if ext2 == "" {
        print("  PASS: extension('Makefile') = ''\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // === FILE SIZE ===
    print("\nTest 8: file.size on non-existent file\n")
    sz, serr = file.size("${tmp}/nonexistent_aether_test_file_xyz")
    if serr != "" {
        print("  PASS: file.size returns error for missing file\n")
    } else {
        println("  FAIL: expected error, got size=${sz}")
        exit(1)
    }

    // === FILE EXISTS ===
    print("\nTest 9: file.exists on non-existent file\n")
    ex = file.exists("${tmp}/nonexistent_aether_test_file_xyz")
    if ex == 0 {
        print("  PASS: file.exists returns 0 for missing file\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // === JSON EDGE CASES ===
    print("\nTest 10: json.parse empty string\n")
    empty_json, eerr = json.parse("")
    if empty_json == null {
        if eerr != "" {
            print("  PASS: json.parse('') returns (null, error)\n")
        } else {
            print("  FAIL: expected error message\n")
            exit(1)
        }
    } else {
        json.free(empty_json)
        print("  FAIL: should return null\n")
        exit(1)
    }

    print("\nTest 11: json.parse simple values\n")
    jn, _ = json.parse("42")
    if json.type(jn) == 2 {
        print("  PASS: json.parse('42') is number\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(jn)

    print("\nTest 12: json.parse null\n")
    jnull, _ = json.parse("null")
    if json.is_null(jnull) == 1 {
        print("  PASS: json.parse('null') is null\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(jnull)

    print("\nTest 13: json.parse nested object\n")
    nested, _ = json.parse("{\"a\":{\"b\":{\"c\":1}}}")
    if json.type(nested) == 5 {
        a, _ = json.object_get(nested, "a")
        b, _ = json.object_get(a, "b")
        c, _ = json.object_get(b, "c")
        if json.get_int(c) == 1 {
            print("  PASS: nested object access works\n")
        } else {
            print("  FAIL: wrong value\n")
            exit(1)
        }
    } else {
        print("  FAIL: not an object\n")
        exit(1)
    }
    json.free(nested)

    print("\nTest 14: json.object_get missing key\n")
    obj, _ = json.parse("{\"x\":1}")
    missing, merr = json.object_get(obj, "y")
    if missing == null {
        if merr == "" {
            print("  PASS: missing key returns (null, empty error)\n")
        } else {
            println("  FAIL: unexpected error for absent key: ${merr}")
            exit(1)
        }
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(obj)

    print("\nTest 15: json.get_string on non-string\n")
    num, _ = json.parse("99")
    s, gsterr = json.get_string(num)
    if gsterr != "" {
        print("  PASS: get_string on number returned error\n")
    } else {
        println("  FAIL: expected error, got s='${s}'")
        exit(1)
    }
    json.free(num)

    // === STRING OPERATIONS ON PLAIN STRINGS (from earlier fix) ===
    print("\nTest 16: string.split on plain string\n")
    parts = string.split("hello world", " ")
    if string.array_size(parts) == 2 {
        print("  PASS: split plain string works\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    string.array_free(parts)

    // === STRING EDGE CASES ===
    print("\nTest 17: string.length on single char\n")
    l = string.length("x")
    if l == 1 {
        print("  PASS: length('x') = 1\n")
    } else {
        print("  FAIL: got ")
        print(l)
        print("\n")
        exit(1)
    }

    print("\nTest 18: string.contains empty substring\n")
    has = string.contains("hello", "")
    if has == 1 {
        print("  PASS: contains empty substring\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\nTest 19: string.index_of not found\n")
    idx = string.index_of("hello", "xyz")
    if idx == 0 - 1 {
        print("  PASS: index_of returns -1 for not found\n")
    } else {
        print("  FAIL: got ")
        print(idx)
        print("\n")
        exit(1)
    }

    print("\nTest 20: string.char_at out of bounds\n")
    ch = string.char_at("hi", 99)
    if ch == 0 {
        print("  PASS: char_at out of bounds returns 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // === FILE WRITE / READ ROUND-TRIP ===
    print("\nTest 21: file write + read round-trip\n")
    test_path = "${tmp}/aether_edge_test.txt"
    we21 = file.write(test_path, "edge case test")
    if we21 != "" { println("  FAIL: write: ${we21}"); exit(1) }
    content, re21 = file.read(test_path)
    if re21 != "" { println("  FAIL: read: ${re21}"); exit(1) }
    if content == "edge case test" {
        print("  PASS: write + read round-trip\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    _ = file.delete(test_path)

    // === JSON ARRAY ===
    print("\nTest 22: json empty array\n")
    earr, _ = json.parse("[]")
    if json.array_size(earr) == 0 {
        print("  PASS: empty array size = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(earr)

    print("\nTest 23: json empty object\n")
    eobj, _ = json.parse("{}")
    if json.type(eobj) == 5 {
        print("  PASS: empty object is type 5\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    json.free(eobj)

    // === MIXED STRING OPS ===
    print("\nTest 24: string.equals managed vs plain\n")
    managed = string.new("hello")
    eq = string.equals(managed, "hello")
    if eq == 1 {
        print("  PASS: managed equals plain\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    string.release(managed)

    print("\nTest 25: string.compare plain strings\n")
    cmp = string.compare("abc", "def")
    if cmp < 0 {
        print("  PASS: compare('abc','def') < 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\n=== All Edge Case Tests Passed ===\n")
}

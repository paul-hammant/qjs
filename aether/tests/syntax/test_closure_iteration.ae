// Test: iteration with closures over std.list

import std.list

// each: iterate a list, calling fn for each element
each(l: ptr, f: fn) {
    n = list.size(l)
    for (i = 0; i < n; i++) {
        val, _ = list.get(l, i)
        call(f, val)
    }
}

// map: transform each element, return new list
map(l: ptr, f: fn) {
    result = list.new()
    n = list.size(l)
    for (i = 0; i < n; i++) {
        val, _ = list.get(l, i)
        mapped = call(f, val)
        list.add(result, mapped)
    }
    return result
}

// filter: keep elements where fn returns nonzero
filter(l: ptr, f: fn) {
    result = list.new()
    n = list.size(l)
    for (i = 0; i < n; i++) {
        val, _ = list.get(l, i)
        keep = call(f, val)
        if keep != 0 {
            list.add(result, val)
        }
    }
    return result
}

main() {
    // Build a list
    nums = list.new()
    defer list.free(nums)
    list.add(nums, 1)
    list.add(nums, 2)
    list.add(nums, 3)
    list.add(nums, 4)
    list.add(nums, 5)

    // each: print all elements
    print("each: ")
    each(nums) |x: int| {
        print(x)
        print(" ")
    }
    print("\n")

    // map: double each element
    doubled = map(nums) |x: int| -> x * 2
    defer list.free(doubled)
    print("map: ")
    each(doubled) |x: int| {
        print(x)
        print(" ")
    }
    print("\n")

    // filter: keep only elements > 2
    big = filter(nums) |x: int| -> x > 2
    defer list.free(big)
    print("filter: ")
    each(big) |x: int| {
        print(x)
        print(" ")
    }
    print("\n")

    println("iteration ok")
}

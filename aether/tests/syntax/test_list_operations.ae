// Test std.list operations
// Covers: new, add, get, set, remove, size, clear, free.
// Uses the Go-style wrappers: list.add returns err, list.get returns
// (value, err).

import std.list

main() {
    print("=== List Operations Tests ===\n\n")

    // Test 1: create and initial size
    print("Test 1: create list\n")
    l = list.new()
    defer list.free(l)
    if list.size(l) == 0 {
        print("  PASS: initial size = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: add elements
    print("\nTest 2: add elements\n")
    _ = list.add(l, 10)
    _ = list.add(l, 20)
    _ = list.add(l, 30)
    if list.size(l) == 3 {
        print("  PASS: size = 3 after 3 adds\n")
    } else {
        print("  FAIL: size = ")
        print(list.size(l))
        print("\n")
        exit(1)
    }

    // Test 3: get elements (Go-style tuple)
    print("\nTest 3: get elements\n")
    v0, _ = list.get(l, 0)
    v1, _ = list.get(l, 1)
    v2, _ = list.get(l, 2)
    if v0 == 10 {
        print("  PASS: get(0) = 10\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if v1 == 20 {
        print("  PASS: get(1) = 20\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if v2 == 30 {
        print("  PASS: get(2) = 30\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 4: remove middle element
    print("\nTest 4: remove(1)\n")
    list.remove(l, 1)
    if list.size(l) == 2 {
        print("  PASS: size = 2 after remove\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    v0b, _ = list.get(l, 0)
    v1b, _ = list.get(l, 1)
    if v0b == 10 {
        print("  PASS: get(0) = 10 after remove\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if v1b == 30 {
        print("  PASS: get(1) = 30 after remove\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 5: clear
    print("\nTest 5: clear\n")
    list.clear(l)
    if list.size(l) == 0 {
        print("  PASS: size = 0 after clear\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 6: add after clear
    print("\nTest 6: add after clear\n")
    _ = list.add(l, 99)
    if list.size(l) == 1 {
        print("  PASS: size = 1 after re-add\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    v99, _ = list.get(l, 0)
    if v99 == 99 {
        print("  PASS: get(0) = 99\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\n=== All List Operations Tests Passed ===\n")
}

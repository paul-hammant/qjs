// Test: file_mtime — file modification timestamps

import std.fs

main() {
    // Existing file has nonzero mtime
    mtime = file_mtime("/etc/hostname")
    if mtime > 0 {
        println("existing file has mtime")
    }

    // mtime is a reasonable Unix timestamp (after year 2000)
    if mtime > 946684800 {
        println("mtime is after year 2000")
    }

    // Nonexistent file returns 0
    bad = file_mtime("/nonexistent/path/file.txt")
    if bad == 0 {
        println("nonexistent returns zero")
    }

    // Null path returns 0
    null_mtime = file_mtime(null)
    if null_mtime == 0 {
        println("null returns zero")
    }

    // Two different files can have different mtimes
    mtime2 = file_mtime("/etc/passwd")
    if mtime != mtime2 || mtime == mtime2 {
        // Just verify both are valid (nonzero) — they may or may not differ
        println("both files have mtimes")
    }

    println("mtime ok")
}

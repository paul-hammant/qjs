// Test: std.dir Go-style tuple wrappers (create, delete, list).

import std.dir

main() {
    tmpdir = "aether_test_dir_tuple_xyz_tmp"

    // Create: returns "" on success
    cerr = dir.create(tmpdir)
    if cerr != "" {
        // If it already exists from a previous run, delete and retry
        dir.delete(tmpdir)
        cerr2 = dir.create(tmpdir)
        if cerr2 != "" {
            println("FAIL: dir.create: ${cerr2}")
            exit(1)
        }
    }

    // List should succeed on a freshly created empty dir
    list, lerr = dir.list(tmpdir)
    if lerr != "" {
        println("FAIL: dir.list: ${lerr}")
        dir.delete(tmpdir)
        exit(1)
    }
    if list == null {
        println("FAIL: dir.list returned null")
        dir.delete(tmpdir)
        exit(1)
    }
    dir.list_free(list)

    // Listing a nonexistent directory — dir_list_raw eagerly allocates
    // an empty DirList rather than returning NULL, so the wrapper can't
    // distinguish "missing" from "empty" without a C-side change. Just
    // verify the call doesn't crash and free whatever comes back.
    empty_list, _ = dir.list("aether_test_nonexistent_dir_xyz_12345")
    if empty_list != null {
        dir.list_free(empty_list)
    }

    // Delete: returns "" on success
    derr = dir.delete(tmpdir)
    if derr != "" {
        println("FAIL: dir.delete: ${derr}")
        exit(1)
    }

    // Delete nonexistent: returns error
    derr2 = dir.delete("aether_test_nonexistent_dir_xyz_12345")
    if derr2 == "" {
        println("FAIL: deleting nonexistent dir should error")
        exit(1)
    }

    println("dir tuple wrappers ok")
}

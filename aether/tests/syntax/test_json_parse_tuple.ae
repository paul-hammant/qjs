// Test: std.json Go-style tuple wrappers.

import std.json

main() {
    // Valid JSON
    v, err = json.parse("{\"name\":\"Aether\",\"n\":42}")
    if err != "" {
        println("FAIL: parse valid json: ${err}")
        exit(1)
    }
    if v == null {
        println("FAIL: parse returned null for valid json")
        exit(1)
    }

    name, ge1 = json.object_get(v, "name")
    if ge1 != "" {
        println("FAIL: object_get name: ${ge1}")
        exit(1)
    }
    s, ge2 = json.get_string(name)
    if ge2 != "" {
        println("FAIL: get_string name: ${ge2}")
        exit(1)
    }
    if s != "Aether" {
        println("FAIL: name field")
        exit(1)
    }
    n_val, ge3 = json.object_get(v, "n")
    if ge3 != "" {
        println("FAIL: object_get n: ${ge3}")
        exit(1)
    }
    if json.get_int(n_val) != 42 {
        println("FAIL: n field")
        exit(1)
    }
    json.free(v)

    // Invalid JSON: parser now returns a position-qualified error rather
    // than a bare NULL.
    _, err2 = json.parse("")
    if err2 == "" {
        println("FAIL: empty json should error")
        exit(1)
    }

    // RFC strictness — partial object is now rejected.
    _, err3 = json.parse("{not valid}")
    if err3 == "" {
        println("FAIL: malformed object should error")
        exit(1)
    }

    // Valid array
    arr, err4 = json.parse("[1, 2, 3]")
    if err4 != "" {
        println("FAIL: parse array: ${err4}")
        exit(1)
    }
    if json.array_size(arr) != 3 {
        println("FAIL: array size")
        exit(1)
    }
    json.free(arr)

    println("json parse tuple ok")
}

// Integration repro for #286 — fuller shape mirroring the original
// 360-line failing file from the downstream svn-aether port.
//
// The original failing function looked like:
//
//     rebuild_dir_impl(repo: string, base_dir_sha: string,
//                       prefix: string, txn: ptr) -> string {
//         rl = ""
//         if string.length(base_dir_sha) > 0 {
//             base_body = svnae_rep_read_blob(repo, base_dir_sha)
//             {
//                 n_entries = aether_dir_count_entries(base_body)
//                 // …more refs to base_body…
//             }
//         }
//         return rl
//     }
//
// On current main pre-fix, this produced 29 "Undefined variable"
// errors against every name declared inside the `if` body and
// then referenced from the nested bare-brace block. The reporter
// suspected a typechecker scope-rule regression; the actual cause
// was the parser eating the inner `{ ... }` as a trailing closure
// of the preceding `svnae_rep_read_blob(...)` call.
//
// This program uses simple Aether-side helpers (no real C externs)
// so the test is self-contained, but exercises the same shape:
//   - non-main function with multi-arg signature
//   - function-call RHS inside an `if` body
//   - nested bare-brace block referencing the outer local
//   - multiple references to the outer local across statements
//   - tail-position return outside the `if`
//
// Pass: program compiles cleanly and prints "ok".

import std.string

extern exit(code: int)

read_blob(repo: string, sha: string) -> string {
    return "${repo}:${sha}:body"
}

count_entries(body: string) -> int {
    return string.length(body)
}

first_entry_name(body: string) -> string {
    return body
}

rebuild_dir_impl(repo: string, base_dir_sha: string,
                  prefix: string) -> string {
    rl = ""
    if string.length(base_dir_sha) > 0 {
        base_body = read_blob(repo, base_dir_sha)
        {
            n_entries = count_entries(base_body)
            if n_entries == 0 {
                return rl
            }
            head_name = first_entry_name(base_body)
            rl = "${prefix}/${head_name}#${n_entries}"
        }
    }
    return rl
}

main() {
    a = rebuild_dir_impl("repoA", "sha1", "/p")
    expected_a = "/p/repoA:sha1:body#15"
    if a != expected_a {
        println("FAIL: got '${a}', want '${expected_a}'")
        exit(1)
    }

    // Empty sha → if-body skipped; rl stays "".
    b = rebuild_dir_impl("repoA", "", "/p")
    if b != "" {
        println("FAIL: empty sha should yield empty rl, got '${b}'")
        exit(1)
    }

    println("ok")
    exit(0)
}

// #260 Tier 2 / Phase E2: WebSocket end-to-end test driver.
//
// Server on port 18110 with one WebSocket route /echo that
// echoes whatever the client sends, prefixed with "echo: ".
// Receives up to 5 messages or until the client closes.

import std.http

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18110

@c_callback echo_handler(req: ptr, ws: ptr, ud: ptr) {
    // Echo every message until the peer closes (ws_recv returns -1)
    // or the loop has served 5 messages. Use a `done` flag rather
    // than `return` because the inferred return type of a handler
    // with a bare `return` doesn't unify with the implicit void.
    n = 0
    done = 0
    while n < 5 && done == 0 {
        kind = http.ws_recv(ws)
        if kind == -1 {
            done = 1
        } else {
            msg = http.ws_message(ws)
            http.ws_send_text(ws, "echo: ${msg}")
            n = n + 1
        }
    }
}

message StartSrv { raw: ptr }
message Noop {}
actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 { println("FAIL: server_create"); exit(1) }

    http.server_websocket(raw, "/echo", echo_handler, null)

    println("READY")

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

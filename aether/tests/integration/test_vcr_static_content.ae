// Step 11 of the Servirtium roadmap — static-content mounts.
//
// Mark a directory as bypass-the-tape so a UI test driver
// (Selenium/Cypress/Playwright) can pull CSS/JS/images straight
// from disk without each one polluting the tape.
//
// What we cover:
//   1. /api/ping is on the tape → served from tape (200 + JSON body)
//   2. /assets/index.html is on disk → served via http_serve_file
//      (200 + file bytes, Content-Type: text/html)
//   3. /assets/hello.txt → 200 + text/plain
//   4. /assets/../etc/passwd → 403 (path traversal rejected)
//   5. /assets/missing.txt → 404
//
// The static-content config is registered BEFORE vcr.load() because
// vcr.load() is what wires routes against the http server.

import std.http.server.vcr
import std.http
import std.http.client
import std.fs
import std.string
import std.json

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18120
const STATIC_ROOT = "/tmp/aether_vcr_static_test"
const TAPE_PATH = "tests/integration/tapes/static_smoke.tape"

message StartVCR { raw: ptr }
message Noop {}

actor VCRActor {
    state s = 0
    receive { StartVCR(raw) -> { s = raw; http_server_start_raw(raw) } }
}

actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

setup_static_root() {
    // Create dir + two files. fs.mkdir_p is idempotent.
    merr = fs.mkdir_p(STATIC_ROOT)
    if merr != "" { println("FAIL: mkdir_p ${STATIC_ROOT}: ${merr}"); exit(1) }

    werr1 = fs.write("${STATIC_ROOT}/index.html",
                     "<html><body>hello from disk</body></html>\n")
    if werr1 != "" { println("FAIL: write index.html: ${werr1}"); exit(1) }

    werr2 = fs.write("${STATIC_ROOT}/hello.txt", "plaintext-from-disk\n")
    if werr2 != "" { println("FAIL: write hello.txt: ${werr2}"); exit(1) }
}

get_status_and_body(url: string) -> {
    creq = client.request("GET", url)
    if creq == null { return -1, "" }
    cresp, cerr = client.send_request(creq)
    client.request_free(creq)
    if cerr != "" { return -2, cerr }
    s = client.response_status(cresp)
    b = client.response_body(cresp)
    body_owned = string.copy(b)
    client.response_free(cresp)
    return s, body_owned
}

main() {
    println("=== VCR static-content smoke test ===\n")

    setup_static_root()

    // Register the mount BEFORE loading the tape. vcr.load() walks
    // both the tape entries and the registered mounts to wire up
    // routes against the http server.
    serr = vcr.static_content("/assets", STATIC_ROOT)
    if serr != "" { println("FAIL: static_content: ${serr}"); exit(1) }

    raw = vcr.load(TAPE_PATH, PORT)
    if raw == null { println("FAIL: vcr.load"); exit(1) }

    spawn(SchedHelper())
    a = spawn(VCRActor())
    a ! StartVCR { raw: raw }
    sleep(500)

    base = "http://127.0.0.1:${PORT}"

    println("Test 1: tape interaction served from tape")
    s1, b1 = get_status_and_body("${base}/api/ping")
    if s1 != 200 { println("  FAIL: status ${s1}"); exit(1) }
    if string.contains(b1, "pong") != 1 {
        println("  FAIL: tape body did not contain 'pong': ${b1}"); exit(1)
    }
    println("  PASS: 200 + ${b1}")

    println("\nTest 2: /assets/index.html served from disk")
    s2, b2 = get_status_and_body("${base}/assets/index.html")
    if s2 != 200 { println("  FAIL: status ${s2}"); exit(1) }
    if string.contains(b2, "hello from disk") != 1 {
        println("  FAIL: index.html body wrong: ${b2}"); exit(1)
    }
    println("  PASS: 200 + ${b2}")

    println("\nTest 3: /assets/hello.txt served from disk")
    s3, b3 = get_status_and_body("${base}/assets/hello.txt")
    if s3 != 200 { println("  FAIL: status ${s3}"); exit(1) }
    if string.contains(b3, "plaintext-from-disk") != 1 {
        println("  FAIL: hello.txt body wrong: ${b3}"); exit(1)
    }
    println("  PASS: 200 + ${b3}")

    println("\nTest 4: /assets/../etc/passwd rejected (403)")
    s4, _ = get_status_and_body("${base}/assets/../etc/passwd")
    if s4 != 403 {
        println("  FAIL: expected 403 from traversal attempt, got ${s4}")
        exit(1)
    }
    println("  PASS: 403")

    println("\nTest 5: /assets/missing.txt returns 404")
    s5, _ = get_status_and_body("${base}/assets/missing.txt")
    if s5 != 404 {
        println("  FAIL: expected 404, got ${s5}")
        exit(1)
    }
    println("  PASS: 404")

    println("\n=== All static-content tests passed ===")
    vcr.eject(raw)
    exit(0)
}

// Step 10 of the Servirtium roadmap — fail playback if the request
// shape diverges from what the tape claims was recorded.
//
// This file: the hostile-tape *headers* subtest. The body subtest
// lives in test_vcr_strict_match_body.ae — separate processes so
// each can keep its actor model simple (the VCR's server-actor
// blocks on accept and there's no clean per-test teardown today).
//
// Tape (verbatim from servirtium/README's broken_recordings/):
//   request_headers_that_never_happened.tape — claims a
//   `should_fail_here: ...` request header was sent. The SUT
//   doesn't send it. Dispatcher must 599 and surface
//   "should_fail_here ... encountered but not expected" via
//   vcr.last_error().
//
// Architecture mirrors test_climate_via_vcr: load the tape, spin
// the VCR up in an actor, drive a single client request, assert
// the response was a 599 AND the right diagnostic landed in
// last_error.

import std.http.server.vcr
import std.http
import std.http.client
import std.string
import std.fs
import std.json

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT_HEADERS = 18110
const PORT_BODY    = 18111

message StartVCR { raw: ptr }
message Noop {}

actor VCRActor {
    state s = 0
    receive { StartVCR(raw) -> { s = raw; http_server_start_raw(raw) } }
}

actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

// Drive a bare GET / against the VCR and return the response status.
// Uses the v2 client request/send_request shape so we can also
// assert on the body. No request body, no extra request headers
// (Host is implicit, set by the transport, and is stripped on the
// matching side).
plain_get(url: string) -> int {
    creq = client.request("GET", url)
    if creq == null { return -1 }
    cresp, cerr = client.send_request(creq)
    client.request_free(creq)
    if cerr != "" { return -2 }
    s = client.response_status(cresp)
    client.response_free(cresp)
    return s
}

main() {
    println("=== VCR strict request matching ===")
    println("\nSubtest 1: tape expects a header the SUT never sent")
    vcr.clear_last_error()

    raw = vcr.load("tests/integration/tapes/request_headers_that_never_happened.tape", PORT_HEADERS)
    if raw == null { println("  FAIL: vcr.load returned null"); exit(1) }

    spawn(SchedHelper())
    a = spawn(VCRActor())
    a ! StartVCR { raw: raw }
    sleep(500)

    url = "http://127.0.0.1:${PORT_HEADERS}/"
    status = plain_get(url)
    if status != 599 {
        println("  FAIL: expected 599 from dispatcher, got ${status}"); exit(1)
    }

    err = vcr.last_error()
    if err == "" {
        println("  FAIL: vcr.last_error() empty after a hostile-tape mismatch"); exit(1)
    }
    if string.contains(err, "should_fail_here") != 1 {
        println("  FAIL: last_error did not mention 'should_fail_here'")
        println("        actual: ${err}")
        exit(1)
    }
    println("  PASS: 599 + last_error='${err}'")

    vcr.eject(raw)

    // NOTE: the second subtest needs a fresh process — the VCR's
    // server-actor blocks on accept() and we can't tear it down
    // cleanly mid-process today. The body-mismatch case has its own
    // test file (test_vcr_strict_match_body.ae).
    println("\n=== Strict-match header subtest passed ===")
    exit(0)
}

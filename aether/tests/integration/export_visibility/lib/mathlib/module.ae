// Public API — declared once at the top via `exports (…)`. Names not
// in the list are private to this module.
exports (double_it, add, PI)

double_it(x) {
    return internal_multiply(x, 2)
}

add(a, b) {
    return a + b
}

const PI = 3

// Private helpers — NOT in the exports list; not accessible from outside.
internal_multiply(a, b) {
    return a * b
}

const SECRET = 42

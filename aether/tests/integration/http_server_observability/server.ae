// #260 Tier 3 (Phase F1+F2): access log + Prometheus metrics test driver.
//
// Server on port 18108. Configures:
//   - Access log in JSON format to a file (path via env)
//   - Per-route metrics on /metrics
//   - One regular route /api/data and one /api/error (returns 500)

import std.http
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18108

handle_data(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "ok")
}

handle_error(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 500)
    http.response_set_body(res, "boom")
}

message StartSrv { raw: ptr }
message Noop {}
actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 { println("FAIL: server_create"); exit(1) }

    log_path = os_getenv("ACCESS_LOG_PATH")
    if log_path == 0 { log_path = "" }
    elog = http.server_set_access_log(raw, "json", log_path)
    if elog != "" { println("FAIL: access_log: ${elog}"); exit(1) }

    em = http.server_set_metrics(raw, "/metrics")
    if em != "" { println("FAIL: metrics: ${em}"); exit(1) }

    println("READY")

    http.server_get(raw, "/api/data",  handle_data,  0)
    http.server_get(raw, "/api/error", handle_error, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

// #260 Tier 0: HTTP/1.1 keep-alive integration test driver.
//
// Spins up an HTTP server on port 18103 with keep-alive enabled
// (max 5 requests per connection, 5s idle timeout). The shell
// runner uses curl to issue 3 requests over a single TCP
// connection and verifies each succeeds.

import std.http
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18103

handle_count(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "ka-ok")
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 {
        println("FAIL: server_create returned null")
        exit(1)
    }

    // Enable keep-alive: max 5 requests per connection, 5-second idle.
    ka_err = http.server_set_keepalive(raw, 1, 5, 5000)
    if ka_err != "" {
        println("FAIL: server_set_keepalive: ${ka_err}")
        exit(1)
    }
    println("READY")

    http.server_get(raw, "/", handle_count, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

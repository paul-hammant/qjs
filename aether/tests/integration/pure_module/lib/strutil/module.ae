// String utility module — tests multi-import alongside mymath.
exports (repeat_sum, MAGIC)

repeat_sum(x, times) {
    total = 0
    for (i = 0; i < times; i = i + 1) {
        total = total + x
    }
    return total
}

const MAGIC = 7

// Private — not listed in exports.
internal_helper(x) {
    return x + 1
}

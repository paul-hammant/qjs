// Regression: contrib.sqlite round-trip against an in-memory
// database. Covers open + DDL + INSERT + SELECT + close.
//
// SQLite isn't auto-detected by the Aether toolchain — the user's
// project opts in via aether.toml `[build] link_flags = "-lsqlite3"`.
// The shell wrapper (test_sqlite_roundtrip.sh) is responsible for
// both adding the `.c` shim via --extra AND checking the build
// produced a valid binary; if the system lacks libsqlite3 the
// wrapper's build step fails and the whole test is marked SKIP.
//
// The probe itself assumes the build succeeded, so once we get here
// sqlite_open(":memory:") must work.

import contrib.sqlite

main() {
    print("=== contrib.sqlite round-trip ===\n\n")

    // ---- Test 1: open in-memory db ----
    print("Test 1: sqlite.open(\":memory:\")\n")
    db, err = sqlite.open(":memory:")
    if err != "" {
        println("  FAIL: open errored: ${err}")
        exit(1)
    }
    if db == null {
        print("  FAIL: open returned null without error\n")
        exit(1)
    }
    print("  PASS\n")

    // ---- Test 2: CREATE TABLE ----
    print("\nTest 2: CREATE TABLE\n")
    cerr = sqlite.exec(db, "CREATE TABLE users (id INTEGER, name TEXT)")
    if cerr != "" {
        println("  FAIL: CREATE errored: ${cerr}")
        exit(1)
    }
    print("  PASS\n")

    // ---- Test 3: INSERT rows ----
    print("\nTest 3: INSERT rows\n")
    ierr1 = sqlite.exec(db, "INSERT INTO users VALUES (1, 'Alice')")
    if ierr1 != "" { println("  FAIL: insert 1: ${ierr1}"); exit(1) }
    ierr2 = sqlite.exec(db, "INSERT INTO users VALUES (2, 'Bob')")
    if ierr2 != "" { println("  FAIL: insert 2: ${ierr2}"); exit(1) }
    ierr3 = sqlite.exec(db, "INSERT INTO users VALUES (3, 'Chen')")
    if ierr3 != "" { println("  FAIL: insert 3: ${ierr3}"); exit(1) }
    print("  PASS: 3 rows\n")

    // ---- Test 4: SELECT returns 3 rows, 2 cols ----
    print("\nTest 4: SELECT * returns the expected shape\n")
    rs, qerr = sqlite.query(db, "SELECT id, name FROM users ORDER BY id")
    if qerr != "" {
        println("  FAIL: query errored: ${qerr}")
        exit(1)
    }
    nrows = sqlite.row_count(rs)
    ncols = sqlite.col_count(rs)
    if nrows != 3 {
        println("  FAIL: expected 3 rows, got ${nrows}")
        exit(1)
    }
    if ncols != 2 {
        println("  FAIL: expected 2 cols, got ${ncols}")
        exit(1)
    }
    print("  PASS: 3 rows x 2 cols\n")

    // ---- Test 5: column names match ----
    print("\nTest 5: column names\n")
    if sqlite.col_name(rs, 0) != "id" {
        println("  FAIL: col 0 got ${sqlite.col_name(rs, 0)}, expected 'id'")
        exit(1)
    }
    if sqlite.col_name(rs, 1) != "name" {
        println("  FAIL: col 1 got ${sqlite.col_name(rs, 1)}, expected 'name'")
        exit(1)
    }
    print("  PASS\n")

    // ---- Test 6: cell values ----
    print("\nTest 6: cell values\n")
    // Row 0 should be (1, "Alice") after ORDER BY id.
    if sqlite.cell(rs, 0, 0) != "1"     { print("  FAIL [0,0]\n"); exit(1) }
    if sqlite.cell(rs, 0, 1) != "Alice" { print("  FAIL [0,1]\n"); exit(1) }
    if sqlite.cell(rs, 1, 0) != "2"     { print("  FAIL [1,0]\n"); exit(1) }
    if sqlite.cell(rs, 1, 1) != "Bob"   { print("  FAIL [1,1]\n"); exit(1) }
    if sqlite.cell(rs, 2, 0) != "3"     { print("  FAIL [2,0]\n"); exit(1) }
    if sqlite.cell(rs, 2, 1) != "Chen"  { print("  FAIL [2,1]\n"); exit(1) }
    print("  PASS: all 6 cells match\n")

    sqlite.free(rs)

    // ---- Test 7: close ----
    print("\nTest 7: sqlite.close\n")
    clerr = sqlite.close(db)
    if clerr != "" {
        println("  FAIL: close errored: ${clerr}")
        exit(1)
    }
    print("  PASS\n")

    print("\n=== All contrib.sqlite tests passed ===\n")
}

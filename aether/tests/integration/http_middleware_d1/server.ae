// #260 Tier 1 / Phase D1: 4 middleware end-to-end test driver.
//
// Spins up an HTTP server on port 18105 with the four pre-handler
// middleware chained: vhost (host gate), basic_auth (creds gate),
// rate_limit (10 req per 5s), cors (open headers). The shell
// runner drives each through curl to verify behaviour.

import std.http
import std.http.middleware

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18105

handle_root(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "ok-mw")
}

// Basic auth verifier: accept only user=alice / pass=secret.
@c_callback verify_creds(username: string, password: string, ud: ptr) -> int {
    if username != "alice" {
        return 0
    }
    if password != "secret" {
        return 0
    }
    return 1
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 { println("FAIL: server_create"); exit(1) }

    // Order matters: vhost first (cheapest reject), then auth, then
    // rate-limit (counted per request that reaches it), then CORS
    // (sets headers on every response). Pre-handler chain runs in
    // registration order.
    e1 = middleware.use_vhost(raw, "localhost,127.0.0.1")
    if e1 != "" { println("FAIL: vhost: ${e1}"); exit(1) }
    e2 = middleware.use_basic_auth(raw, "Restricted", verify_creds, null)
    if e2 != "" { println("FAIL: auth: ${e2}"); exit(1) }
    e3 = middleware.use_rate_limit(raw, 10, 5000)
    if e3 != "" { println("FAIL: rate: ${e3}"); exit(1) }
    e4 = middleware.use_cors(raw, "*", "GET, POST, OPTIONS",
                              "Content-Type, Authorization", 0, 600)
    if e4 != "" { println("FAIL: cors: ${e4}"); exit(1) }
    println("READY")

    http.server_get(raw, "/", handle_root, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

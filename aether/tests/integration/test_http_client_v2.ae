// Regression: std.http.client v2 — request builder, full response
// access, case-insensitive header lookup, explicit timeouts, binary
// bodies. Self-contained: spins up an in-process Aether HTTP echo
// server in an actor, then makes client calls against it on the
// main thread. No shell wrapper, no subprocess management, no port
// dance — both halves of the test live in the same Aether binary.
//
// Mirrors the test_integration.ae pattern from contrib/tinyweb.
//
// Plan matrix from http-client-improvement-plan.md §"Testing surface":
//
//   1. request_set_header round-trip
//   2. response_header lookup (case-insensitive)
//   3. response_status discrimination (200, 404, 403, 500 distinct)
//   4. request_set_body sends the right Content-Length header
//   5. request_set_timeout enforcement (server delays > timeout)
//   6. send_request transport failure (refused connection)
//   7. v1 wrappers still work (http.get round-trips a 200 OK body)

import std.http.client
import std.http
import std.string
import std.json

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int
// `sleep(ms)` is a built-in Aether primitive — declaring it as
// `extern` here triggers a conflicting-types error at C codegen
// time because Aether's `int` parameter renders as `int` while
// libc's `sleep(unsigned int)` is the prevailing prototype.

// Tests bind to a high port to dodge the more popular numbers
// (8080 = tinyweb tests, 9222 = aether_ui tests).
const PORT = 18091

// ------------------------------------------------------------------
// Echo-server handlers — one per route the probe will hit.
// ------------------------------------------------------------------

handle_echo_header(req: ptr, res: ptr, ud: ptr) {
    v = http.get_header(req, "X-Test-Foo")
    http.response_set_status(res, 200)
    http.response_set_body(res, v)
}

handle_sets_header(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "X-Server-Tag", "alpha")
    // Second header used by the #269 multi-header-snapshot regression
    // (Test 2b below). The two values have different lengths so the
    // bug — both vars reading the same TLS slot — is observable.
    http.response_set_header(res, "X-Other-Tag", "longer-different-value")
    http.response_set_body(res, "ok")
}

handle_ok(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_body(res, "ok-body")
}

handle_notfound(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 404)
    http.response_set_body(res, "missing")
}

handle_forbidden(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 403)
    http.response_set_body(res, "denied")
}

handle_broken(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 500)
    http.response_set_body(res, "broken")
}

handle_echo_length(req: ptr, res: ptr, ud: ptr) {
    // Echo back the Content-Length header. Can't trust
    // http.request_body's length on binary input — server's body
    // accessor is NUL-terminated-string-shaped, so a NUL-bearing
    // payload comes back length-of-prefix even though the wire
    // carried all bytes. Content-Length proves the client built
    // and sent the right header.
    cl = http.get_header(req, "Content-Length")
    http.response_set_status(res, 200)
    http.response_set_body(res, cl)
}

handle_slow(req: ptr, res: ptr, ud: ptr) {
    // 3 seconds — well above the probe's 1s timeout for Test 5.
    // sleep is in milliseconds.
    sleep(3000)
    http.response_set_status(res, 200)
    http.response_set_body(res, "late")
}

// JSON sugar handlers (issue #240). The echo handler asserts that
// the client set Content-Type: application/json and emits a
// well-formed JSON response keyed off what it received. The broken
// handler emits non-JSON regardless of the request — used to drive
// response_body_json's parse-failure path.
handle_json_echo(req: ptr, res: ptr, ud: ptr) {
    ctype = http.get_header(req, "Content-Type")
    body  = http.request_body(req)
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "application/json")
    // Synthesise a small object that proves the round-trip preserved
    // both the request's content-type header and its body.
    out = "{\"echoed_ct\":\"${ctype}\",\"echoed_body\":${body}}"
    http.response_set_body(res, out)
}

handle_json_broken(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "application/json")
    http.response_set_body(res, "this is not { valid json")
}

// HEAD/PATCH handlers (issue #241). /head-target sets Content-Length
// and an X-Marker header so the test can verify head() returns the
// raw header block. /patch-echo echoes the request method + body
// back so the test can verify patch() actually fired a PATCH.
handle_head_target(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "X-Marker", "head-marker-value")
    http.response_set_header(res, "Content-Length", "42")
    // No body — HEAD by spec, but the server framework lets us set
    // one anyway. The client should treat this as headers-only.
    http.response_set_body(res, "")
}

handle_patch_echo(req: ptr, res: ptr, ud: ptr) {
    method = http.request_method(req)
    body   = http.request_body(req)
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "method=${method} body=${body}")
}

// Redirect handlers (issue #239 cases 8-10). Each returns a 301 with
// a Location header. The chain depth is encoded in the route path so
// the test can drive multi-hop, single-hop, and self-loop variants
// against the same in-process server. Relative Location values
// exercise http_resolve_location's "root-relative" path.
handle_redirect_3(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 301)
    http.response_set_header(res, "Location", "/redirect-2")
    http.response_set_body(res, "")
}

handle_redirect_2(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 301)
    http.response_set_header(res, "Location", "/redirect-1")
    http.response_set_body(res, "")
}

handle_redirect_1(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 301)
    http.response_set_header(res, "Location", "/ok")
    http.response_set_body(res, "")
}

// Self-loop — Location points back at the same path. The redirect
// loop detector (visited-URL tracking) must short-circuit this with
// an error rather than spinning until max_hops.
handle_redirect_self(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 301)
    http.response_set_header(res, "Location", "/redirect-self")
    http.response_set_body(res, "")
}

// Absolute Location URL — exercises http_resolve_location's
// "absolute URL" branch (instead of the relative-path branch above).
handle_redirect_absolute(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 302)
    http.response_set_header(res, "Location", "http://127.0.0.1:18091/ok")
    http.response_set_body(res, "")
}

// ------------------------------------------------------------------
// Server actor — owns the blocking accept loop. The companion
// SchedHelper is empty-on-purpose: the multicore scheduler needs
// at least two registered actors before main() reliably yields back,
// so the helper is a no-op spawned before the server. (Same trick
// the broader tests in the tree use; tracking the underlying
// requirement is a separate scheduler-ergonomics question.)
// ------------------------------------------------------------------

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive {
        StartSrv(raw) -> {
            s = raw
            http_server_start_raw(raw)
        }
    }
}

actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

// ------------------------------------------------------------------
// Test helpers
// ------------------------------------------------------------------

base_url() -> string {
    return "http://127.0.0.1:${PORT}"
}

check_status(path: string, want: int) -> string {
    req = client.request("GET", "${base_url()}${path}")
    client.set_timeout(req, 5)
    resp, err = client.send_request(req)
    client.request_free(req)
    if err != "" { return "transport on ${path}: ${err}" }
    got = client.response_status(resp)
    client.response_free(resp)
    if got != want { return "status on ${path}: got ${got}, want ${want}" }
    return ""
}

// ------------------------------------------------------------------
// Main — register routes, kick the actor, sleep briefly, run tests.
// ------------------------------------------------------------------

main() {
    print("=== std.http.client v2 ===\n\n")

    raw = http.server_create(PORT)
    if raw == 0 {
        print("FAIL: server_create returned 0\n")
        exit(1)
    }

    http.server_get (raw, "/echo-header/X-Test-Foo", handle_echo_header,  0)
    http.server_get (raw, "/sets-header",            handle_sets_header,  0)
    http.server_get (raw, "/ok",                     handle_ok,           0)
    http.server_get (raw, "/notfound",               handle_notfound,     0)
    http.server_get (raw, "/forbidden",              handle_forbidden,    0)
    http.server_get (raw, "/broken",                 handle_broken,       0)
    http.server_post(raw, "/echo-length",            handle_echo_length,  0)
    http.server_get (raw, "/slow",                   handle_slow,         0)
    http.server_post(raw, "/json-echo",              handle_json_echo,    0)
    http.server_get (raw, "/json-broken",            handle_json_broken,  0)
    http.server_add_route(raw, "HEAD",  "/head-target", handle_head_target, 0)
    http.server_add_route(raw, "PATCH", "/patch-echo",  handle_patch_echo,  0)
    // Redirect chain endpoints (issue #239 cases 8-10).
    http.server_get(raw, "/redirect-3",        handle_redirect_3,        0)
    http.server_get(raw, "/redirect-2",        handle_redirect_2,        0)
    http.server_get(raw, "/redirect-1",        handle_redirect_1,        0)
    http.server_get(raw, "/redirect-self",     handle_redirect_self,     0)
    http.server_get(raw, "/redirect-absolute", handle_redirect_absolute, 0)

    // Hand the server to an actor that calls server_start (blocking).
    // SchedHelper spawned first to satisfy the >=2-actor scheduler
    // requirement (without it, main() never yields back from sleep).
    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    // Brief grace period for the actor to bind the port.
    sleep(500)

    // ---- Test 1: request_set_header round-trip ----
    print("Test 1: request_set_header round-trip\n")
    req1 = client.request("GET", "${base_url()}/echo-header/X-Test-Foo")
    if req1 == null { print("  FAIL: request null\n"); exit(1) }
    e1 = client.set_header(req1, "X-Test-Foo", "alpha-beta-gamma")
    if e1 != "" { println("  FAIL set_header: ${e1}"); exit(1) }
    e1t = client.set_timeout(req1, 5)
    if e1t != "" { println("  FAIL set_timeout: ${e1t}"); exit(1) }
    resp1, err1 = client.send_request(req1)
    client.request_free(req1)
    if err1 != "" { println("  FAIL transport: ${err1}"); exit(1) }
    body1 = client.response_body(resp1)
    if string.contains(body1, "alpha-beta-gamma") != 1 {
        println("  FAIL: server didn't echo the header; body='${body1}'")
        exit(1)
    }
    client.response_free(resp1)
    print("  PASS\n")

    // ---- Test 2: response_header case-insensitive lookup ----
    print("\nTest 2: response_header case-insensitive lookup\n")
    req2 = client.request("GET", "${base_url()}/sets-header")
    client.set_timeout(req2, 5)
    resp2, err2 = client.send_request(req2)
    client.request_free(req2)
    if err2 != "" { println("  FAIL transport: ${err2}"); exit(1) }
    tag = client.response_header(resp2, "x-server-tag")  // wrong case on purpose
    if string.equals(tag, "alpha") != 1 {
        println("  FAIL: header lookup mismatched; got '${tag}', want 'alpha'")
        exit(1)
    }
    print("  PASS\n")

    // ---- Test 2b: response_header doesn't alias prior return (#269) ----
    // Pre-fix the underlying http_response_header_raw returned a
    // borrowed pointer into a thread-local buffer that the next call
    // overwrote — `tag` and `other` would both point to the same
    // (clobbered) slot, and `string.length(tag)` would report the
    // length of `other`'s value rather than `tag`'s. The fix in
    // std/http/client/module.ae snapshots via string.copy on return.
    other = client.response_header(resp2, "x-other-tag")
    if string.equals(other, "longer-different-value") != 1 {
        println("  FAIL: second header mismatched; got '${other}'")
        exit(1)
    }
    // Critical: re-read `tag` — pre-fix this would now read the
    // clobbered slot and return "longer-different-value".
    if string.equals(tag, "alpha") != 1 {
        println("  FAIL: tag aliased after second response_header call (#269); got '${tag}'")
        exit(1)
    }
    if string.length(tag) != 5 {
        println("  FAIL: tag length aliased; got ${string.length(tag)}, want 5")
        exit(1)
    }
    if string.length(other) != 22 {
        println("  FAIL: other length wrong; got ${string.length(other)}, want 22")
        exit(1)
    }
    client.response_free(resp2)
    print("  PASS: response_header snapshot — concurrent values don't alias (#269)\n")

    // ---- Test 3: status discrimination — 200 / 404 / 403 / 500 ----
    print("\nTest 3: status discrimination\n")
    s_200 = check_status("/ok",        200)
    if s_200 != "" { println("  FAIL ${s_200}"); exit(1) }
    s_404 = check_status("/notfound",  404)
    if s_404 != "" { println("  FAIL ${s_404}"); exit(1) }
    s_403 = check_status("/forbidden", 403)
    if s_403 != "" { println("  FAIL ${s_403}"); exit(1) }
    s_500 = check_status("/broken",    500)
    if s_500 != "" { println("  FAIL ${s_500}"); exit(1) }
    print("  PASS: 200, 404, 403, 500 each distinguished\n")

    // ---- Test 4: client emits the right Content-Length header ----
    // Build a 6-byte body and verify the server saw Content-Length: 6.
    // Binary-NUL coverage isn't possible here without a fs.read_binary
    // sidecar (Aether literals can't hold NUL bytes); the v2 client's
    // binary-safe body path is exercised separately by the client's
    // own unit-level usage in the cryptography / fs tests via the
    // shared AetherString unwrap helper.
    print("\nTest 4: POST sends correct Content-Length\n")
    req4 = client.request("POST", "${base_url()}/echo-length")
    client.set_body(req4, "abcdef", 6, "application/octet-stream")
    client.set_timeout(req4, 5)
    resp4, err4 = client.send_request(req4)
    client.request_free(req4)
    if err4 != "" { println("  FAIL transport: ${err4}"); exit(1) }
    body4 = client.response_body(resp4)
    if string.equals(body4, "6") != 1 {
        println("  FAIL: server saw Content-Length '${body4}', want '6'")
        exit(1)
    }
    client.response_free(resp4)
    print("  PASS: Content-Length 6 reached the server\n")

    // ---- Test 5: timeout enforcement ----
    print("\nTest 5: timeout enforcement\n")
    req5 = client.request("GET", "${base_url()}/slow")
    client.set_timeout(req5, 1)
    resp5, err5 = client.send_request(req5)
    client.request_free(req5)
    if err5 == "" {
        client.response_free(resp5)
        print("  FAIL: expected timeout error, got success\n")
        exit(1)
    }
    print("  PASS: client.send_request returned error '${err5}'\n")

    // ---- Test 6: transport failure on refused connection ----
    print("\nTest 6: refused connection on a closed port\n")
    req6 = client.request("GET", "http://127.0.0.1:1/nope")  // port 1 = ICMP, will refuse
    client.set_timeout(req6, 3)
    _, err6 = client.send_request(req6)
    client.request_free(req6)
    if err6 == "" {
        print("  FAIL: expected error, connection somehow succeeded\n")
        exit(1)
    }
    print("  PASS: refused connection reported as '${err6}'\n")

    // ---- Test 7: v1 wrappers still work ----
    print("\nTest 7: v1 http.get backward-compat\n")
    body7, err7 = http.get("${base_url()}/ok")
    if err7 != "" { println("  FAIL v1 get: ${err7}"); exit(1) }
    if string.contains(body7, "ok-body") != 1 {
        println("  FAIL v1 body wrong: '${body7}'")
        exit(1)
    }
    print("  PASS\n")

    // ---- Test 8: post_json round-trip (issue #240) ----
    // Build a small JSON object, POST it to /json-echo, parse the
    // response, assert the server received Content-Type: application/json
    // and the body we sent. json_* externs are flat-namespaced (no
    // wrapper for create_object / object_set_raw etc. yet); call them
    // directly. The error legs of object_get / get_string come back
    // as (value, err) tuples per std.json's idiom.
    print("\nTest 8: post_json round-trip\n")
    name_val = json_create_string("alice")
    age_val  = json_create_number(30.0)
    payload  = json_create_object()
    json_object_set_raw(payload, "name", name_val)
    json_object_set_raw(payload, "age",  age_val)
    resp8, err8 = client.post_json("${base_url()}/json-echo", payload)
    if err8 != "" { println("  FAIL post_json: ${err8}"); exit(1) }
    if client.response_status(resp8) != 200 {
        println("  FAIL status ${client.response_status(resp8)}"); exit(1)
    }
    parsed8, perr8 = client.response_body_json(resp8)
    if perr8 != "" { println("  FAIL parse: ${perr8}"); exit(1) }
    ct_node, gctterr = json.object_get(parsed8, "echoed_ct")
    if gctterr != "" { println("  FAIL no echoed_ct: ${gctterr}"); exit(1) }
    echoed_ct, sctterr = json.get_string(ct_node)
    if sctterr != "" { println("  FAIL get_string ct: ${sctterr}"); exit(1) }
    if string.contains(echoed_ct, "application/json") != 1 {
        println("  FAIL echoed_ct '${echoed_ct}' missing application/json")
        exit(1)
    }
    echoed_body, ebgerr = json.object_get(parsed8, "echoed_body")
    if ebgerr != "" { println("  FAIL no echoed_body: ${ebgerr}"); exit(1) }
    eb_name_node, ebnnerr = json.object_get(echoed_body, "name")
    if ebnnerr != "" { println("  FAIL no echoed name: ${ebnnerr}"); exit(1) }
    eb_name, ebnsstrerr = json.get_string(eb_name_node)
    if ebnsstrerr != "" { println("  FAIL get_string name: ${ebnsstrerr}"); exit(1) }
    if eb_name != "alice" {
        println("  FAIL round-tripped name '${eb_name}' != 'alice'"); exit(1)
    }
    json_free(parsed8)
    client.response_free(resp8)
    json_free(payload)
    print("  PASS: round-trip preserved Content-Type and body\n")

    // ---- Test 9: response_body_json happy path ----
    // Use post_json with a trivial payload to drive a JSON response,
    // then verify response_body_json parses it cleanly.
    print("\nTest 9: response_body_json happy path\n")
    p9 = json_create_object()
    resp9, err9 = client.post_json("${base_url()}/json-echo", p9)
    if err9 != "" { println("  FAIL: ${err9}"); exit(1) }
    parsed9, perr9 = client.response_body_json(resp9)
    if perr9 != "" { println("  FAIL parse: ${perr9}"); exit(1) }
    if parsed9 == null { println("  FAIL parsed9 null"); exit(1) }
    json_free(parsed9)
    client.response_free(resp9)
    json_free(p9)
    print("  PASS: parsed cleanly\n")

    // ---- Test 10: response_body_json malformed JSON surfaces err ----
    print("\nTest 10: response_body_json on malformed JSON\n")
    req10 = client.request("GET", "${base_url()}/json-broken")
    client.set_timeout(req10, 5)
    resp10, err10 = client.send_request(req10)
    client.request_free(req10)
    if err10 != "" { println("  FAIL transport: ${err10}"); exit(1) }
    parsed10, perr10 = client.response_body_json(resp10)
    if perr10 == "" {
        println("  FAIL: expected parse error, got success")
        exit(1)
    }
    if parsed10 != null {
        println("  FAIL: expected null value on parse failure")
        exit(1)
    }
    client.response_free(resp10)
    print("  PASS: parse error surfaced as '${perr10}'\n")

    // ---- Test 11: head() returns (status, headers, err) tuple ----
    // Issue #241. /head-target sets X-Marker and Content-Length;
    // the wrapper should hand back the header block as a string.
    print("\nTest 11: head() shorthand\n")
    h_status, h_headers, h_err = client.head("${base_url()}/head-target")
    if h_err != "" { println("  FAIL transport: ${h_err}"); exit(1) }
    if h_status != 200 { println("  FAIL status ${h_status}"); exit(1) }
    if string.contains(h_headers, "X-Marker: head-marker-value") != 1 {
        println("  FAIL headers missing X-Marker; got '${h_headers}'")
        exit(1)
    }
    print("  PASS: 200 + X-Marker present\n")

    // ---- Test 12: patch() sends PATCH method, echoed by server ----
    // Issue #241. /patch-echo echoes "method=PATCH body=...".
    print("\nTest 12: patch() shorthand\n")
    p_resp, p_err = client.patch("${base_url()}/patch-echo",
                                 "patch-payload", "text/plain")
    if p_err != "" { println("  FAIL transport: ${p_err}"); exit(1) }
    p_body = client.response_body(p_resp)
    p_status = client.response_status(p_resp)
    if p_status != 200 { println("  FAIL status ${p_status}"); exit(1) }
    if string.contains(p_body, "method=PATCH") != 1 {
        println("  FAIL: expected method=PATCH; got '${p_body}'")
        exit(1)
    }
    if string.contains(p_body, "body=patch-payload") != 1 {
        println("  FAIL: expected body=patch-payload; got '${p_body}'")
        exit(1)
    }
    client.response_free(p_resp)
    print("  PASS: PATCH method + body round-tripped\n")

    // ---- Test 13: redirect chain — 3 hops, response_url returns final URL ----
    // Issue #239 acceptance criterion: client.set_follow_redirects(req, N)
    // walks the chain and lands at the terminal 200; response_url
    // reflects the final hop, not the original request URL.
    print("\nTest 13: redirect chain (3 hops, relative Locations)\n")
    req13 = client.request("GET", "${base_url()}/redirect-3")
    client.set_follow_redirects(req13, 5)
    client.set_timeout(req13, 5)
    resp13, err13 = client.send_request(req13)
    client.request_free(req13)
    if err13 != "" { println("  FAIL transport: ${err13}"); exit(1) }
    s13 = client.response_status(resp13)
    if s13 != 200 {
        println("  FAIL: expected final 200 after chain; got ${s13}")
        exit(1)
    }
    body13 = client.response_body(resp13)
    if string.contains(body13, "ok-body") != 1 {
        println("  FAIL: terminal body wrong; got '${body13}'")
        exit(1)
    }
    final_url = client.response_url(resp13)
    if string.contains(final_url, "/ok") != 1 {
        println("  FAIL: response_url '${final_url}' should end at /ok")
        exit(1)
    }
    if string.contains(final_url, "/redirect-3") == 1 {
        println("  FAIL: response_url '${final_url}' still points at original")
        exit(1)
    }
    client.response_free(resp13)
    print("  PASS: chain walked, response_url = '${final_url}'\n")

    // ---- Test 14: max_hops exceeded surfaces a clear error ----
    // The chain /redirect-3 → /redirect-2 → /redirect-1 → /ok needs 3
    // hops to reach 200. With max_hops=2 the third 301 is left
    // unfollowed; the response carries the last 3xx status and the
    // error string flags hop-limit exhaustion.
    print("\nTest 14: redirect hop limit exceeded\n")
    req14 = client.request("GET", "${base_url()}/redirect-3")
    client.set_follow_redirects(req14, 2)  // intentionally too low
    client.set_timeout(req14, 5)
    resp14, err14 = client.send_request(req14)
    client.request_free(req14)
    if err14 != "" { println("  FAIL transport: ${err14}"); exit(1) }
    s14 = client.response_status(resp14)
    if s14 < 300 || s14 >= 400 {
        println("  FAIL: expected to stop at a 3xx; got ${s14}")
        exit(1)
    }
    rerr14 = client.response_redirect_error(resp14)
    if string.contains(rerr14, "hop limit") != 1 {
        println("  FAIL: expected 'hop limit' redirect_error; got '${rerr14}'")
        exit(1)
    }
    client.response_free(resp14)
    print("  PASS: stopped at 3xx with '${rerr14}'\n")

    // ---- Test 15: redirect-loop short-circuits on revisited URL ----
    // /redirect-self points back at itself. The visited-URL detector
    // must surface a "loop detected" error rather than spinning until
    // max_hops is exhausted.
    print("\nTest 15: redirect loop detection\n")
    req15 = client.request("GET", "${base_url()}/redirect-self")
    client.set_follow_redirects(req15, 10)  // generous; detector should fire well before
    client.set_timeout(req15, 5)
    resp15, err15 = client.send_request(req15)
    client.request_free(req15)
    if err15 != "" { println("  FAIL transport: ${err15}"); exit(1) }
    rerr15 = client.response_redirect_error(resp15)
    if string.contains(rerr15, "loop") != 1 {
        println("  FAIL: expected 'loop' redirect_error; got '${rerr15}'")
        exit(1)
    }
    client.response_free(resp15)
    print("  PASS: loop detected as '${rerr15}'\n")

    // ---- Test 16: absolute Location URL resolves correctly ----
    // /redirect-absolute returns "Location: http://127.0.0.1:18091/ok".
    // http_resolve_location should accept the absolute form and the
    // chain should land on /ok.
    print("\nTest 16: redirect with absolute Location URL\n")
    req16 = client.request("GET", "${base_url()}/redirect-absolute")
    client.set_follow_redirects(req16, 3)
    client.set_timeout(req16, 5)
    resp16, err16 = client.send_request(req16)
    client.request_free(req16)
    if err16 != "" { println("  FAIL transport: ${err16}"); exit(1) }
    s16 = client.response_status(resp16)
    if s16 != 200 {
        println("  FAIL: expected 200 after absolute redirect; got ${s16}")
        exit(1)
    }
    body16 = client.response_body(resp16)
    if string.contains(body16, "ok-body") != 1 {
        println("  FAIL: terminal body wrong; got '${body16}'")
        exit(1)
    }
    client.response_free(resp16)
    print("  PASS: absolute Location resolved to terminal 200\n")

    print("\n=== All std.http.client v2 tests passed ===\n")
    // Explicit exit because the SrvActor's accept loop would
    // otherwise keep the process alive forever.
    exit(0)
}

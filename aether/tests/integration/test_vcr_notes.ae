// Step 9 of the Servirtium roadmap: per-interaction "Note" annotations.
//
// vcr.note(title, body) stages a note; the next recorded interaction
// picks it up and the on-disk tape carries a `## [Note] <title>:`
// block between the interaction heading and its ### sections.
// Playback ignores the block (the loader walks ### sections only,
// so anything at ## level except `## Interaction ` is naturally
// dropped).
//
// What we cover:
//   1. note() before record() attaches to that record
//   2. record() without a preceding note() emits no [Note] block
//   3. last-writer-wins when note() is called twice in a row
//   4. parser tolerates a tape containing notes (loads cleanly,
//      tape_length matches what was recorded)

import std.http.server.vcr
import std.http
import std.fs
import std.string
import std.io

extern exit(code: int)

// Platform temp dir — TEMP on Windows, TMPDIR on POSIX, /tmp as a
// last-resort fallback. A bare "/tmp/..." path doesn't work on Windows
// because the MinGW C runtime resolves it as drive-relative (e.g.
// C:\tmp\) and most runners (including GitHub Actions) don't create
// that directory. Computed at runtime since `const` can't call functions.
tape_path() -> {
    tmp = io.getenv("TEMP")
    if tmp == 0 { tmp = io.getenv("TMPDIR") }
    if tmp == 0 { tmp = "/tmp" }
    return "${tmp}/vcr_notes_test.tape"
}

assert_contains(haystack: string, needle: string, label: string) {
    if string.contains(haystack, needle) != 1 {
        println("  FAIL: ${label} — expected to find '${needle}'")
        exit(1)
    }
}

assert_not_contains(haystack: string, needle: string, label: string) {
    if string.contains(haystack, needle) == 1 {
        println("  FAIL: ${label} — did not expect '${needle}' but found it")
        exit(1)
    }
}

main() {
    println("=== VCR notes smoke test ===\n")

    TAPE_PATH = tape_path()

    // ---- Test 1: note() before record() ----
    println("Test 1: note attaches to next interaction")
    nerr1 = vcr.note("Mary", "Mary had a little lamb,\n   Its fleece was white as snow.\n")
    if nerr1 != "" { println("  FAIL: note — ${nerr1}"); exit(1) }
    rerr1 = vcr.record("GET", "/lamb", 200, "text/plain", "lamb-body")
    if rerr1 != "" { println("  FAIL: record — ${rerr1}"); exit(1) }

    // Test 2 setup: a second interaction with no preceding note().
    rerr2 = vcr.record("GET", "/no-note", 200, "text/plain", "plain-body")
    if rerr2 != "" { println("  FAIL: record #2 — ${rerr2}"); exit(1) }

    // Test 3 setup: note() twice in a row — last wins.
    vcr.note("Wrong", "this should never appear")
    vcr.note("Bo Peep", "Little Bo Peep has lost her sheep.")
    rerr3 = vcr.record("GET", "/sheep", 200, "text/plain", "sheep-body")
    if rerr3 != "" { println("  FAIL: record #3 — ${rerr3}"); exit(1) }

    // Flush + read back.
    ferr = vcr.flush(TAPE_PATH)
    if ferr != "" { println("  FAIL: flush — ${ferr}"); exit(1) }
    on_disk, derr = fs.read(TAPE_PATH)
    if derr != "" { println("  FAIL: read back — ${derr}"); exit(1) }

    // Mary's note must be present, attached to interaction 0.
    assert_contains(on_disk, "## [Note] Mary:", "Mary note heading missing")
    assert_contains(on_disk, "Mary had a little lamb", "Mary note body missing")

    // The /no-note interaction must NOT carry a note. Easiest check:
    // the substring "/no-note\n\n### Request headers" should appear
    // (no [Note] heading wedged between the path and the first
    // section).
    assert_contains(on_disk, "/no-note\n\n### Request headers", "interaction 1 unexpectedly carries a [Note]")

    // Bo Peep wins the last-writer race; "Wrong" is dropped.
    assert_contains(on_disk, "## [Note] Bo Peep:", "Bo Peep note missing")
    assert_contains(on_disk, "Little Bo Peep has lost her sheep", "Bo Peep body missing")
    assert_not_contains(on_disk, "## [Note] Wrong:", "stale note survived overwrite")
    assert_not_contains(on_disk, "this should never appear", "stale note body survived overwrite")
    println("  PASS")

    // ---- Test 2: parser tolerates the notes on reload ----
    // Loading the just-flushed tape should yield 3 interactions; the
    // notes are present in the markdown but the loader skips them
    // (record-only feature, playback ignores).
    println("\nTest 2: parser tolerates note blocks on reload")
    raw = vcr.load(TAPE_PATH, 18105)
    if raw == null { println("  FAIL: vcr.load returned null"); exit(1) }
    n = vcr.tape_length()
    if n != 3 {
        println("  FAIL: expected 3 interactions after reload, got ${n}")
        exit(1)
    }
    vcr.eject(raw)
    println("  PASS: ${n} interactions reloaded")

    println("\n=== All VCR note tests passed ===")
    exit(0)
}

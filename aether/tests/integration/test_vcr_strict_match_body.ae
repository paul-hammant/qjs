// Step 10 — hostile-tape body mismatch.
//
// Tape (verbatim from servirtium/README's broken_recordings/):
//   request_body_that_never_happened.tape — claims a specific
//   request body was sent. The SUT sends none. Dispatcher must
//   599 and surface "request body different to expectation"
//   via vcr.last_error().
//
// Companion to test_vcr_strict_match.ae (the headers case);
// they live in separate test processes because the VCR's
// server-actor blocks on accept() and we don't have clean
// per-test teardown.

import std.http.server.vcr
import std.http
import std.http.client
import std.string
import std.fs
import std.json

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18112

message StartVCR { raw: ptr }
message Noop {}

actor VCRActor {
    state s = 0
    receive { StartVCR(raw) -> { s = raw; http_server_start_raw(raw) } }
}

actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    println("=== VCR strict request body matching ===\n")

    vcr.clear_last_error()

    raw = vcr.load("tests/integration/tapes/request_body_that_never_happened.tape", PORT)
    if raw == null {
        println("FAIL: vcr.load returned null")
        exit(1)
    }

    spawn(SchedHelper())
    a = spawn(VCRActor())
    a ! StartVCR { raw: raw }
    sleep(500)

    // SUT sends a plain GET / with no body. Tape claims a non-empty
    // body was previously recorded → mismatch.
    creq = client.request("GET", "http://127.0.0.1:${PORT}/")
    if creq == null { println("FAIL: client.request returned null"); exit(1) }
    cresp, cerr = client.send_request(creq)
    client.request_free(creq)
    if cerr != "" { println("FAIL: client transport: ${cerr}"); exit(1) }
    status = client.response_status(cresp)
    client.response_free(cresp)

    if status != 599 {
        println("FAIL: expected 599 from dispatcher, got ${status}")
        exit(1)
    }

    err = vcr.last_error()
    if err == "" {
        println("FAIL: vcr.last_error() empty after a hostile-tape mismatch")
        exit(1)
    }
    if string.contains(err, "request body different") != 1 {
        println("FAIL: last_error did not mention 'request body different'")
        println("       actual: ${err}")
        exit(1)
    }

    println("PASS: 599 + last_error='${err}'")
    println("\n=== Strict-match body subtest passed ===")
    vcr.eject(raw)
    exit(0)
}

// #260 Tier 1 / Phase D2: 4 more middleware end-to-end test driver.
//
// Server on port 18106 with all 4 D2 middleware installed:
//   - rewrite      : /old/* -> /api/*
//   - static_files : /static/* -> read from /tmp/static-test/
//   - gzip         : compress responses >= 64 bytes
//   - error_pages  : custom 404 + custom 500 bodies
//
// The runner pre-creates the static dir, drives requests, and
// verifies behaviour.

import std.http
import std.http.middleware
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int
extern aether_rewrite_opts_new() -> ptr
extern aether_error_pages_opts_new() -> ptr

const PORT = 18106

handle_api(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    // ~200-byte body so gzip kicks in (min_size = 64).
    http.response_set_body(res,
        "this is the api response body, it is long enough to be gzip compressed by the middleware. lorem ipsum dolor sit amet consectetur adipiscing elit sed do.")
}

handle_kaboom(req: ptr, res: ptr, ud: ptr) {
    // Always 500 — the error_pages transformer should swap the body.
    http.response_set_status(res, 500)
    http.response_set_body(res, "raw 500 body")
}

message StartSrv { raw: ptr }
message Noop {}
actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 { println("FAIL: server_create"); exit(1) }

    // 1. rewrite — /old/* -> /api/*
    rw_opts = aether_rewrite_opts_new()
    middleware.rewrite_add_rule(rw_opts, "/old/", "/api/")
    middleware.use_rewrite(raw, rw_opts)

    // 2. static_files — /static/* -> $STATIC_ROOT (set by the runner;
    //    MSYS-converted path on Windows, plain /tmp path elsewhere).
    static_root = os_getenv("STATIC_ROOT")
    if static_root == 0 || static_root == "" {
        println("FAIL: STATIC_ROOT must be set by the runner")
        exit(1)
    }
    middleware.use_static_files(raw, "/static", static_root)

    // 3. gzip — compress responses >= 64 bytes
    middleware.use_gzip(raw, 64, 6)

    // 4. error_pages — custom 404 + 500
    ep_opts = aether_error_pages_opts_new()
    middleware.error_pages_register(ep_opts, 404,
        "<html><body><h1>Custom Not Found</h1></body></html>",
        "text/html; charset=utf-8")
    middleware.error_pages_register(ep_opts, 500,
        "<html><body><h1>Custom Internal Error</h1></body></html>",
        "text/html; charset=utf-8")
    middleware.use_error_pages(raw, ep_opts)

    println("READY")

    http.server_get(raw, "/api/data", handle_api, 0)
    http.server_get(raw, "/kaboom",   handle_kaboom, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

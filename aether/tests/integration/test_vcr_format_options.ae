// Step 12 of the Servirtium roadmap — optional markdown format.
//
// Two formatting toggles, recorder-only, both fully optional:
//   1. emphasize_http_verbs() emits *GET* instead of bare GET
//   2. indent_code_blocks() emits 4-space-indented blocks instead
//      of triple-backtick fences
//
// Playback tolerates either form regardless of toggles.
//
// What we cover:
//   1. Replay of a hand-written tape that uses both alternative
//      forms. The dispatcher must serve the recorded response
//      identically to a fenced/bare-verb tape — proves the parser
//      adapts.
//   2. Recorder side: enable both toggles, record an interaction,
//      flush, read back the markdown, assert the file contains
//      *GET* and a 4-space-indented body line.
//   3. With toggles off, re-flush emits the canonical fenced/bare
//      form (back-compat sanity check).

import std.http.server.vcr
import std.http
import std.http.client
import std.fs
import std.string
import std.io
import std.json

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18130
const ALT_TAPE  = "tests/integration/tapes/alt_format.tape"

// Platform temp dir — TEMP on Windows, TMPDIR on POSIX, /tmp fallback.
// A bare "/tmp/..." path is drive-relative on the MinGW C runtime
// (e.g. C:\tmp\) and the directory typically doesn't exist on CI.
flush_out_path() -> {
    tmp = io.getenv("TEMP")
    if tmp == 0 { tmp = io.getenv("TMPDIR") }
    if tmp == 0 { tmp = "/tmp" }
    return "${tmp}/vcr_format_options_test.tape"
}

message StartVCR { raw: ptr }
message Noop {}

actor VCRActor {
    state s = 0
    receive { StartVCR(raw) -> { s = raw; http_server_start_raw(raw) } }
}

actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

assert_contains(haystack: string, needle: string, label: string) {
    if string.contains(haystack, needle) != 1 {
        println("  FAIL: ${label} — expected to find '${needle}'")
        exit(1)
    }
}

assert_not_contains(haystack: string, needle: string, label: string) {
    if string.contains(haystack, needle) == 1 {
        println("  FAIL: ${label} — did not expect '${needle}' but found it")
        exit(1)
    }
}

main() {
    println("=== VCR markdown format options ===\n")

    FLUSH_OUT = flush_out_path()

    // ---- Test 1: replay an alternative-form tape ----
    println("Test 1: replay tape using *GET* + 4-space-indented body")
    raw = vcr.load(ALT_TAPE, PORT)
    if raw == null { println("  FAIL: vcr.load"); exit(1) }

    spawn(SchedHelper())
    a = spawn(VCRActor())
    a ! StartVCR { raw: raw }
    sleep(500)

    creq = client.request("GET", "http://127.0.0.1:${PORT}/alt")
    cresp, cerr = client.send_request(creq)
    client.request_free(creq)
    if cerr != "" { println("  FAIL: transport: ${cerr}"); exit(1) }
    s1 = client.response_status(cresp)
    b1 = client.response_body(cresp)
    body1_owned = string.copy(b1)
    client.response_free(cresp)
    if s1 != 200 { println("  FAIL: status ${s1}"); exit(1) }
    if string.contains(body1_owned, "alternative-form-body") != 1 {
        println("  FAIL: body wrong: ${body1_owned}"); exit(1)
    }
    println("  PASS: 200 + ${body1_owned}")

    vcr.eject(raw)

    // ---- Test 2: recorder emits the alternative forms when toggled ----
    println("\nTest 2: recorder emits *GET* + indented blocks when toggles set")
    // Capture an interaction directly via vcr.record (no live HTTP needed).
    rerr = vcr.record("GET", "/foo", 200, "text/plain", "line-one\nline-two\n")
    if rerr != "" { println("  FAIL: record: ${rerr}"); exit(1) }

    vcr.emphasize_http_verbs()
    vcr.indent_code_blocks()
    ferr = vcr.flush(FLUSH_OUT)
    if ferr != "" { println("  FAIL: flush: ${ferr}"); exit(1) }

    on_disk, derr = fs.read(FLUSH_OUT)
    if derr != "" { println("  FAIL: read back: ${derr}"); exit(1) }

    // Header carries *GET* not bare GET. /foo may live at index 0 or
    // 1 depending on whether the previous test's load() left an entry
    // in the tape buffer; only the verb-formatting matters here.
    assert_contains(on_disk, "*GET* /foo", "emphasized verb missing")
    // Body line carried with 4-space indent. Triple-backtick fence
    // must NOT be in the file.
    assert_contains(on_disk, "    line-one", "indented body line missing")
    assert_contains(on_disk, "    line-two", "second indented body line missing")
    assert_not_contains(on_disk, "```", "fenced form leaked into indented output")
    println("  PASS")

    // ---- Test 3: clearing toggles restores fenced/bare form ----
    println("\nTest 3: clear_format_options restores defaults")
    vcr.clear_format_options()
    ferr2 = vcr.flush(FLUSH_OUT)
    if ferr2 != "" { println("  FAIL: re-flush: ${ferr2}"); exit(1) }
    on_disk2, derr2 = fs.read(FLUSH_OUT)
    if derr2 != "" { println("  FAIL: re-read: ${derr2}"); exit(1) }

    assert_contains(on_disk2, "GET /foo", "default heading missing")
    assert_not_contains(on_disk2, "*GET*", "emphasized verb survived clear")
    assert_contains(on_disk2, "```", "fence missing after clear")
    println("  PASS")

    println("\n=== All format-option tests passed ===")
    exit(0)
}

// Regression: contrib.sqlite v2 — prepare / bind / step / column /
// reset / finalize. Covers every primitive the subversion port
// (~/scm/subversion/) needs to drop its hand-written shim.c. Plan
// matrix is in sqlite-improvement-plan.md §"Testing surface to add
// upstream".
//
// 8 cases:
//   1. bind_int + bind_text round-trip via INSERT + SELECT WHERE
//   2. bind_i64 round-trip across the 32-bit boundary (>= 2^31)
//   3. bind_blob round-trip preserving embedded NULs
//   4. prepare failure -> null + non-empty errmsg(db)
//   5. step returns SQLITE_DONE on no-row INSERT, SQLITE_ROW on hit
//   6. reset + re-bind + re-step (one statement, two rows)
//   7. changes(db) after a multi-row UPDATE
//   8. finalize then fresh prepare on the same SQL (no handle leak)

import contrib.sqlite

main() {
    print("=== contrib.sqlite v2 prepared-statement matrix ===\n\n")

    db, oerr = sqlite.open(":memory:")
    if oerr != "" { println("FAIL open: ${oerr}"); exit(1) }

    schema_err = sqlite.exec(db, "CREATE TABLE t (k TEXT PRIMARY KEY, v INT, big INT, blob BLOB)")
    if schema_err != "" { println("FAIL CREATE: ${schema_err}"); exit(1) }

    // ---- Test 1: bind_int + bind_text round-trip ----
    print("Test 1: bind_int + bind_text\n")
    ins, perr = sqlite.prepare(db, "INSERT INTO t (k, v) VALUES (?, ?)")
    if perr != "" { println("  FAIL prepare insert: ${perr}"); exit(1) }
    if ins == null { print("  FAIL prepare insert returned null\n"); exit(1) }

    e1 = sqlite.bind_text(ins, 1, "alpha"); if e1 != "" { println("  FAIL bind_text: ${e1}"); exit(1) }
    e2 = sqlite.bind_int (ins, 2, 42);      if e2 != "" { println("  FAIL bind_int: ${e2}"); exit(1) }
    rc1, serr1 = sqlite.step(ins, db)
    if serr1 != "" { println("  FAIL step: ${serr1}"); exit(1) }
    if rc1 != sqlite.SQLITE_DONE { println("  FAIL step rc ${rc1}, want SQLITE_DONE"); exit(1) }
    sqlite.finalize(ins)

    sel, perr2 = sqlite.prepare(db, "SELECT v FROM t WHERE k = ?")
    if perr2 != "" { println("  FAIL prepare select: ${perr2}"); exit(1) }
    sqlite.bind_text(sel, 1, "alpha")
    rc2, serr2 = sqlite.step(sel, db)
    if serr2 != "" { println("  FAIL step select: ${serr2}"); exit(1) }
    if rc2 != sqlite.SQLITE_ROW { println("  FAIL select rc ${rc2}, want SQLITE_ROW"); exit(1) }
    got = sqlite.column_int(sel, 0)
    if got != 42 { println("  FAIL got ${got}, want 42"); exit(1) }
    sqlite.finalize(sel)
    print("  PASS\n")

    // ---- Test 2: bind_i64 across the 32-bit boundary ----
    print("\nTest 2: bind_i64 across the 32-bit boundary (>= 2^31)\n")
    // Pick 2^33 + 7 = 8589934599. hi = 2, lo = 7.
    big_hi = 2
    big_lo = 7
    ins2, p2err = sqlite.prepare(db, "INSERT INTO t (k, big) VALUES (?, ?)")
    if p2err != "" { println("  FAIL prepare: ${p2err}"); exit(1) }
    sqlite.bind_text(ins2, 1, "big_one")
    eb = sqlite.bind_i64(ins2, 2, big_hi, big_lo)
    if eb != "" { println("  FAIL bind_i64: ${eb}"); exit(1) }
    rc3, serr3 = sqlite.step(ins2, db)
    if serr3 != "" { println("  FAIL step: ${serr3}"); exit(1) }
    if rc3 != sqlite.SQLITE_DONE { println("  FAIL rc ${rc3}"); exit(1) }
    sqlite.finalize(ins2)

    sel2, _ = sqlite.prepare(db, "SELECT big FROM t WHERE k = ?")
    sqlite.bind_text(sel2, 1, "big_one")
    sqlite.step(sel2, db)
    rh, rl = sqlite.column_i64(sel2, 0)
    if rh != big_hi { println("  FAIL hi ${rh}, want ${big_hi}"); exit(1) }
    if rl != big_lo { println("  FAIL lo ${rl}, want ${big_lo}"); exit(1) }
    sqlite.finalize(sel2)
    print("  PASS: 2^33+7 round-trips\n")

    // ---- Test 3: bind_blob with embedded NULs ----
    print("\nTest 3: bind_blob preserves embedded NULs\n")
    // Make a 4-byte blob {0x01, 0x00, 0x02, 0x00} via concat tricks?
    // Easier: use an Aether string with explicit length. But Aether
    // string literals can't contain NUL. So we INSERT a known
    // pattern via a CAST-from-hex SQL expression for the seed, then
    // SELECT it back into a length-aware AetherString and re-INSERT
    // it via bind_blob to verify the bind path preserves NULs.
    sqlite.exec(db, "INSERT INTO t (k, blob) VALUES ('seed', X'01000200')")

    sel3, _ = sqlite.prepare(db, "SELECT blob FROM t WHERE k = ?")
    sqlite.bind_text(sel3, 1, "seed")
    sqlite.step(sel3, db)
    bytes, n_bytes, berr = sqlite.column_blob(sel3, 0)
    if berr != "" { println("  FAIL column_blob: ${berr}"); exit(1) }
    if n_bytes != 4 { println("  FAIL got ${n_bytes} bytes, want 4"); exit(1) }
    sqlite.finalize(sel3)

    // Now bind that 4-byte AetherString back via bind_blob and read
    // it again. If bind_blob were strlen-based it would truncate at
    // byte 1 (the first NUL).
    ins3, _ = sqlite.prepare(db, "INSERT INTO t (k, blob) VALUES (?, ?)")
    sqlite.bind_text(ins3, 1, "rebound")
    sqlite.bind_blob(ins3, 2, bytes, n_bytes)
    sqlite.step(ins3, db)
    sqlite.finalize(ins3)

    sel3b, _ = sqlite.prepare(db, "SELECT blob FROM t WHERE k = ?")
    sqlite.bind_text(sel3b, 1, "rebound")
    sqlite.step(sel3b, db)
    rb, rn, _ = sqlite.column_blob(sel3b, 0)
    if rn != 4 {
        println("  FAIL re-bound blob is ${rn} bytes, want 4 (strlen-truncation?)")
        exit(1)
    }
    sqlite.finalize(sel3b)
    print("  PASS: 4-byte NUL-bearing blob round-trips through bind_blob\n")

    // ---- Test 4: prepare failure surfaces a non-empty errmsg ----
    print("\nTest 4: prepare failure produces null + errmsg\n")
    bad, berr2 = sqlite.prepare(db, "SELEC bogus FROM nowhere")
    if bad != null { print("  FAIL: bad SQL prepared OK\n"); exit(1) }
    if berr2 == "" { print("  FAIL: errmsg empty after prepare failure\n"); exit(1) }
    print("  PASS: prepare returned null with errmsg='${berr2}'\n")

    // ---- Test 5: SQLITE_DONE on no-row INSERT, SQLITE_ROW on hit ----
    print("\nTest 5: SQLITE_DONE / SQLITE_ROW on the right operations\n")
    // INSERT was tested in T1; here we just confirm a SELECT with
    // no rows returns SQLITE_DONE on first step, and a SELECT that
    // hits returns SQLITE_ROW.
    sel5miss, _ = sqlite.prepare(db, "SELECT v FROM t WHERE k = 'nope'")
    rcm, _ = sqlite.step(sel5miss, db)
    if rcm != sqlite.SQLITE_DONE { println("  FAIL miss rc ${rcm}, want SQLITE_DONE"); exit(1) }
    sqlite.finalize(sel5miss)

    sel5hit, _ = sqlite.prepare(db, "SELECT v FROM t WHERE k = 'alpha'")
    rch, _ = sqlite.step(sel5hit, db)
    if rch != sqlite.SQLITE_ROW { println("  FAIL hit rc ${rch}, want SQLITE_ROW"); exit(1) }
    sqlite.finalize(sel5hit)
    print("  PASS\n")

    // ---- Test 6: reset + re-bind + re-step ----
    print("\nTest 6: reset + re-bind + re-step (one stmt, two rows)\n")
    ins6, _ = sqlite.prepare(db, "INSERT INTO t (k, v) VALUES (?, ?)")
    sqlite.bind_text(ins6, 1, "row1"); sqlite.bind_int(ins6, 2, 100)
    rc6a, _ = sqlite.step(ins6, db)
    if rc6a != sqlite.SQLITE_DONE { print("  FAIL step1\n"); exit(1) }

    rerr = sqlite.reset(ins6)
    if rerr != "" { println("  FAIL reset: ${rerr}"); exit(1) }
    sqlite.bind_text(ins6, 1, "row2"); sqlite.bind_int(ins6, 2, 200)
    rc6b, _ = sqlite.step(ins6, db)
    if rc6b != sqlite.SQLITE_DONE { print("  FAIL step2\n"); exit(1) }
    sqlite.finalize(ins6)

    // Verify both rows are there.
    rs, _ = sqlite.query(db, "SELECT k, v FROM t WHERE k IN ('row1','row2') ORDER BY k")
    if sqlite.row_count(rs) != 2 { println("  FAIL: expected 2 rows, got ${sqlite.row_count(rs)}"); exit(1) }
    sqlite.free(rs)
    print("  PASS: two rows inserted via one reset-loop statement\n")

    // ---- Test 7: changes(db) after multi-row UPDATE ----
    print("\nTest 7: changes(db) after multi-row UPDATE\n")
    sqlite.exec(db, "UPDATE t SET v = 999 WHERE k IN ('row1','row2')")
    n_changed = sqlite.changes(db)
    if n_changed != 2 { println("  FAIL: changes=${n_changed}, want 2"); exit(1) }
    print("  PASS: changes(db) = 2\n")

    // ---- Test 8: finalize + fresh prepare on the same SQL ----
    print("\nTest 8: finalize then fresh prepare on the same SQL\n")
    s8a, _ = sqlite.prepare(db, "SELECT v FROM t WHERE k = ?")
    sqlite.bind_text(s8a, 1, "alpha")
    sqlite.step(s8a, db)
    fe = sqlite.finalize(s8a)
    if fe != "" { println("  FAIL finalize: ${fe}"); exit(1) }

    s8b, p8berr = sqlite.prepare(db, "SELECT v FROM t WHERE k = ?")
    if p8berr != "" { println("  FAIL re-prepare: ${p8berr}"); exit(1) }
    sqlite.bind_text(s8b, 1, "alpha")
    rc8, _ = sqlite.step(s8b, db)
    if rc8 != sqlite.SQLITE_ROW { print("  FAIL re-prepared step\n"); exit(1) }
    sqlite.finalize(s8b)
    print("  PASS: re-prepare on the same SQL works\n")

    sqlite.close(db)
    print("\n=== All contrib.sqlite v2 tests passed ===\n")
}

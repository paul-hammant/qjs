// Issue #261: contrib/host/tinygo regression driver.
//
// Loads the c-shared library at $TINYGO_LIB (built from
// contrib/host/tinygo/examples/greet.go), then invokes one call per
// pre-defined wrapper signature.

import contrib.host.tinygo
import std.os

main() {
    lib_path = os_getenv("TINYGO_LIB")
    if lib_path == 0 {
        println("FAIL: TINYGO_LIB unset")
        return
    }

    handle, err = tinygo.load(lib_path)
    if handle == null {
        println("FAIL: load: ${err}")
        return
    }

    answer = tinygo.call_int_void(handle, "Answer")
    println("Answer = ${answer}")

    sum = tinygo.call_int_int_int(handle, "Add", 2, 40)
    println("Add(2, 40) = ${sum}")

    neg = tinygo.call_int_int(handle, "Negate", 7)
    println("Negate(7) = ${neg}")

    msg = tinygo.call_str_str(handle, "Greet", "world")
    println(msg)

    tinygo.unload(handle)
}

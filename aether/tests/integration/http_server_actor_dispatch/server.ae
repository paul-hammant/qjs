// #260 Tier 0 / Phase C3: parallel keep-alive sessions through the
// drain helper. The thread-pool path already exercises
// http_server_drain_connection via handle_client_connection (which
// just delegates). This test adds the parallel-load shape — 4
// concurrent clients each reusing their TCP connection across many
// requests, verifying the drain path doesn't drop / interleave /
// corrupt anything under contention.

import std.http
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18104

handle_echo(req: ptr, res: ptr, ud: ptr) {
    // Echo a header so the runner can verify the right session got
    // the right response (no cross-session pollution).
    sid = http.get_header(req, "X-Session-Id")
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "echo:${sid}")
}

message StartSrv { raw: ptr }
message Noop {}
actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 {
        println("FAIL: server_create")
        exit(1)
    }

    // Generous keep-alive: 100 requests per connection, 10s idle.
    err = http.server_set_keepalive(raw, 1, 100, 10000)
    if err != "" {
        println("FAIL: keepalive: ${err}")
        exit(1)
    }
    println("READY")

    http.server_get(raw, "/echo", handle_echo, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

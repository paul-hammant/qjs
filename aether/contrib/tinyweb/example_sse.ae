// Server-Sent Events (SSE) Example — streaming events to browser clients

import contrib.tinyweb
import std.http
import std.string
import std.list
import std.map
import std.tcp


main() {
    println("=== TinyWeb SSE + Chunked Example ===\n")

    server = tinyweb.web_server_full("localhost", 8080, 0, 8082) {

        tinyweb.end_point(tinyweb.GET, "/") |req: ptr, res: ptr, ctx: ptr| {
            tinyweb.response_set_header(res, "Content-Type", "text/html")
            tinyweb.response_write(res, "<!DOCTYPE html>
<html>
<head><title>TinyWeb SSE Demo</title></head>
<body>
  <h1>Server-Sent Events</h1>
  <div id=\"events\"></div>
  <script>
    var source = new EventSource('http://localhost:8082/sse/events');
    source.onmessage = function(e) {
      var div = document.getElementById('events');
      div.innerHTML += '<p>' + e.data + '</p>';
    };
    source.addEventListener('tick', function(e) {
      var div = document.getElementById('events');
      div.innerHTML += '<p><b>tick:</b> ' + e.data + '</p>';
    });
  </script>
</body>
</html>")
        }

        tinyweb.path("/sse") {
            tinyweb.sse_endpoint("/events") |stream: ptr| {
                tinyweb.sse_send(stream, "Initial event")
                tinyweb.sse_send_event(stream, "tick", "1")
                tinyweb.sse_send(stream, "Event 1")
                tinyweb.sse_send_event(stream, "tick", "2")
                tinyweb.sse_send(stream, "Event 2")
                tinyweb.sse_send_event(stream, "tick", "3")
                tinyweb.sse_comment(stream, "keep-alive")
                tinyweb.sse_send(stream, "Final event")
            }
        }
    }

    println("Starting HTTP server on localhost:8080...")
    println("Starting SSE server on localhost:8082...")
    println("")
    println("Open http://localhost:8080/ or: curl -N http://localhost:8082/sse/events")

    result = tinyweb.tw_start(server)
    if result != 0 { println("ERROR: Failed to start server") }
    tinyweb.tw_stop(server)
}

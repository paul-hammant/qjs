// Step 2 of the Servirtium roadmap (servirtium.dev →
// starting-a-new-implementation.md). The same five climate tests
// from test_climate_real.ae, but routed through std.http.server.vcr's
// replayer instead of the real network. Same assertions, same
// expected values, no internet involvement at runtime.
//
// The point of this test (per the README): proving that the
// playback path returns identical results to the real-network path,
// so a developer working offline / on a flaky network / against a
// since-changed upstream still gets meaningful test signal.
//
// Tape lives at contrib/climate_http_tests/tapes/climate_5_endpoints.tape and
// was captured verbatim from the GitHub-Pages mirror once. The five
// interactions are consumed in the order the test makes them.
//
// Architecture:
//   - VCR is std.http.server.vcr, listening on port 18099.
//   - climate.get_ave_annual_rainfall_from(base_url, ...) is pointed
//     at http://127.0.0.1:18099 (the VCR's bind address) instead of
//     the GitHub-Pages mirror, so the same client code drives both
//     real-network (test_climate_real.ae) and replayed (this test)
//     modes.
//   - The 5 assertions are word-for-word the same as test_climate_real's.

import contrib.climate_http_tests.get_ave_annual_rainfall_from
import std.http.server.vcr
import std.http
import std.http.client
import std.string
import std.fs
import std.json

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18099

// VCR address — the climate client gets pointed at this instead of
// the real GitHub-Pages mirror.
const BASE_URL = "http://127.0.0.1:18099"

// Server-actor + scheduler-helper pattern. Same shape every other
// in-process-server test in this repo uses (tinyweb integration tests,
// the v2 client test). Aether's module merger doesn't transitively
// merge actor declarations across modules in v0.1, so the actor pair
// lives in the test rather than in the VCR module itself.

message StartVCR { raw: ptr }
message Noop {}

actor VCRActor {
    state s = 0
    receive { StartVCR(raw) -> { s = raw; http_server_start_raw(raw) } }
}

actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

// Float compare with tolerance — same 1e-7 the real-network test uses.
close_enough(got: float, want: float) -> int {
    diff = got - want
    if diff < 0.0 { diff = 0.0 - diff }
    if diff < 0.0000001 { return 1 }
    return 0
}

main() {
    println("=== contrib.climate_http_tests via VCR ===\n")

    raw = vcr.load("contrib/climate_http_tests/tapes/climate_5_endpoints.tape", PORT)
    if raw == null {
        println("FAIL: tape failed to load")
        exit(1)
    }
    n = vcr.tape_length()
    println("VCR loaded with ${n} interactions; spinning server up on port ${PORT}")

    spawn(SchedHelper())
    a = spawn(VCRActor())
    a ! StartVCR { raw: raw }
    sleep(500)

    // ---- Test 1: gbr 1980-1999 ----
    println("\nTest 1: gbr 1980-1999 mean rainfall")
    gbr, gerr = get_ave_annual_rainfall_from(BASE_URL, 1980, 1999, "gbr")
    if gerr != "" { println("  FAIL transport/server: ${gerr}"); exit(1) }
    if close_enough(gbr, 988.8454972331015) != 1 {
        println("  FAIL: got ${gbr}, want 988.8454972331015")
        exit(1)
    }
    println("  PASS: ${gbr}")

    // ---- Test 2: fra 1980-1999 ----
    println("\nTest 2: fra 1980-1999 mean rainfall")
    fra, ferr = get_ave_annual_rainfall_from(BASE_URL, 1980, 1999, "fra")
    if ferr != "" { println("  FAIL: ${ferr}"); exit(1) }
    if close_enough(fra, 913.7986955122727) != 1 {
        println("  FAIL: got ${fra}, want 913.7986955122727")
        exit(1)
    }
    println("  PASS: ${fra}")

    // ---- Test 3: egy 1980-1999 ----
    println("\nTest 3: egy 1980-1999 mean rainfall")
    egy, eerr = get_ave_annual_rainfall_from(BASE_URL, 1980, 1999, "egy")
    if eerr != "" { println("  FAIL: ${eerr}"); exit(1) }
    if close_enough(egy, 54.58587712129825) != 1 {
        println("  FAIL: got ${egy}, want 54.58587712129825")
        exit(1)
    }
    println("  PASS: ${egy}")

    // ---- Test 4: gbr 1985-1995 — unsupported date range ----
    println("\nTest 4: gbr 1985-1995 — unsupported date range")
    _, derr = get_ave_annual_rainfall_from(BASE_URL, 1985, 1995, "gbr")
    if string.contains(derr, "date range not supported") != 1 {
        println("  FAIL: expected date-range error, got '${derr}'")
        exit(1)
    }
    println("  PASS: '${derr}'")

    // ---- Test 5: mde — bad country code ----
    println("\nTest 5: mde — bad country code")
    _, mderr = get_ave_annual_rainfall_from(BASE_URL, 1980, 1999, "mde")
    if string.contains(mderr, "bad country code") != 1 {
        println("  FAIL: expected bad-country error, got '${mderr}'")
        exit(1)
    }
    println("  PASS: '${mderr}'")

    println("\n=== All 5 climate-via-VCR tests passed ===")
    vcr.eject(raw)
    // exit explicitly — the VCR actor's blocking accept loop would
    // otherwise keep the process alive.
    exit(0)
}

// contrib.climate — small client for the WorldBank climate XML API.
//
// Demo / TCK target for the Servirtium-Aether story. Mirrors the
// climate-API pattern every other Servirtium reference implementation
// uses (Java, Kotlin, Python, Go, Ruby, ...) so we can adopt the same
// test cases and ultimately the same recorded tapes for cross-impl
// compatibility (Servirtium README's starting-a-new-implementation.md
// step 16).
//
// Data source: a static mirror of the original WorldBank climate API
// hosted at https://servirtium.github.io/worldbank-climate-recordings/
// (the original `climatedataapi.worldbank.org` is offline). The mirror
// returns the same XML the original used to, so Aether-side parsing
// matches what the other impls do.
//
// XML format per request:
//
//   <list>
//     <domain.web.AnnualGcmDatum>
//       <gcm>...</gcm>
//       <annualData>
//         <double>988.95</double>
//       </annualData>
//     </domain.web.AnnualGcmDatum>
//     ... (15 GCM models per call)
//   </list>
//
// "Average annual rainfall" is the arithmetic mean of every <double>
// value in the response. README's expected gbr value is 988.8454972331015
// — verified to be the mean of the 15 doubles in the gbr response.
//
// Failure modes the API expresses through body content rather than
// HTTP status (the upstream returns 200 either way):
//   - bad country code (e.g. "mde") → body is the literal text
//     "Invalid country code. Three letters are required"
//   - unsupported date range (e.g. 1985–1995) → body is "<list/>"
//
// The Aether wrapper turns each into a non-empty error string so
// callers branch on `(value, err)` rather than parsing the body.
//
// Backend selection: callers can pass a base_url to point at a
// different host (e.g. a localhost VCR replayer for step 2 of the
// Servirtium roadmap). Default is the GitHub-Pages mirror.

import std.http.client
import std.string

exports (DEFAULT_BASE, get_ave_annual_rainfall_from)

// Default base URL — the GitHub-Pages mirror of WorldBank's climate
// XML API. Swap to "http://127.0.0.1:18091" or similar when driving
// the test through a local VCR replayer.
const DEFAULT_BASE = "https://servirtium.github.io/worldbank-climate-recordings"

// Compute the average annual rainfall (in mm) for a country between
// two years, hitting `base_url` for the data. Returns
// (mean_rainfall, "") on success, (0.0, error_string) on:
//   - bad country code
//   - unsupported date range
//   - HTTP transport failure
//   - HTTP status outside 2xx
//   - malformed response body (no <double> values found)
//
// The 30-second timeout is explicit (no implicit defaults in
// std.http.client v2). Callers wanting different timeout behaviour
// should drop down to the v2 client surface directly.
get_ave_annual_rainfall_from(base_url: string, from_year: int, to_year: int, country: string) -> {
    url = "${base_url}/climateweb/rest/v1/country/annualavg/pr/${from_year}/${to_year}/${country}.xml"

    req = client.request("GET", url)
    if req == null { return 0.0, "could not build request" }
    client.set_timeout(req, 30)
    resp, terr = client.send_request(req)
    client.request_free(req)
    if terr != "" { return 0.0, terr }

    status = client.response_status(resp)
    body = client.response_body(resp)
    // Copy the body string out before freeing the response — the
    // string returned by response_body is owned by the response and
    // becomes invalid after free.
    body_owned = string.copy(body)
    client.response_free(resp)

    if status < 200 || status >= 300 {
        return 0.0, "http status ${status}"
    }

    if string.contains(body_owned, "Invalid country code") == 1 {
        return 0.0, "bad country code"
    }

    // Parse out every <double>...</double> value, average them.
    sum = 0.0
    count = 0
    pos = 0
    n_body = string.length(body_owned)
    OPEN  = "<double>"
    CLOSE = "</double>"
    open_len = string.length(OPEN)
    while pos < n_body {
        open_at = string.index_of_from(body_owned, OPEN, pos)
        if open_at < 0 { break }
        val_start = open_at + open_len
        close_at = string.index_of_from(body_owned, CLOSE, val_start)
        if close_at < 0 { break }
        slice = string.substring(body_owned, val_start, close_at)
        // string.to_double (not to_float) — float in Aether today is
        // 32-bit and either truncates these values or interacts oddly
        // with println formatting; double-precision parses correctly.
        v, perr = string.to_double(slice)
        if perr == "" {
            sum = sum + v
            count = count + 1
        }
        pos = close_at + 1
    }

    if count == 0 {
        return 0.0, "date range not supported"
    }

    return sum / count, ""
}

// (Convenience overload `get_ave_annual_rainfall(from, to, country)`
// using DEFAULT_BASE was tried but tripped Aether's tuple-return
// inference — the typechecker conflated the forwarded tuple's
// (float, string) shape with an unrelated (int, int) tuple in the
// same translation unit and emitted broken C. Callers explicitly
// pass the base URL today via get_ave_annual_rainfall_from; once
// that inference issue is fixed the convenience overload comes
// back. Tracking separately as an upstream filing.)

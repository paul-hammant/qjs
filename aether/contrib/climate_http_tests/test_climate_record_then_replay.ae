// Step 3 of the Servirtium roadmap (servirtium.dev →
// starting-a-new-implementation.md): self-recording + replay.
//
// Auto mode: tape file absent → record (proxy each request to the
// real upstream, capture both directions, write tape on completion).
// Tape file present → replay (serve recorded responses, no upstream
// involvement).
//
// First run of this test against a missing tape will:
//   1. Spin up the VCR with proxy handlers for the 5 known paths
//   2. Run the climate API client against http://127.0.0.1:VCR_PORT
//   3. Each handler forwards to the real GitHub-Pages mirror and
//      captures (method, path, status, content-type, body)
//   4. After all 5 calls, flush the captured set to the tape file
//   5. Same 5 assertions as the existing real / replay tests
//
// Every subsequent run loads the tape and replays without touching
// the network, identical to test_climate_via_vcr.ae but using a tape
// we recorded ourselves rather than one written by hand.
//
// Lifecycle of the recorded tape file:
//   - Committed at contrib/climate_http_tests/tapes/climate_5_endpoints.tape
//     (the canonical fixture, byte-identical to what the recorder
//     produces against the GitHub-Pages mirror as of 2026-04-25).
//   - CI runs always replay against the committed tape (exercises
//     the replay path end-to-end without needing outbound HTTPS).
//   - Local dev: same default. Delete the file + re-run to exercise
//     the recorder path against the live mirror; set AETHER_VCR_RECORD=1
//     to drive the re-record byte-diff check (step 4).
//
// If the recorder writes a tape that diverges from the committed
// one, that's either a recorder bug or an upstream change — both
// worth knowing about. flush_or_check() surfaces the diff offset.

import contrib.climate_http_tests.get_ave_annual_rainfall_from
import std.http.server.vcr
import std.http
import std.http.client
import std.fs

// std.fs.file_exists is exposed only via per-symbol import, which
// in v0.90 hides the namespace `fs` from the rest of the file.
// Declare the extern directly so we keep the `fs.read` / `fs.write`
// surface that the vcr module's parser/emitter transitively needs.
extern file_exists(path: string) -> int
import std.string
import std.io
import std.json

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18100
const VCR_BASE = "http://127.0.0.1:18100"
const UPSTREAM_BASE = "https://servirtium.github.io/worldbank-climate-recordings"
const TAPE_PATH = "contrib/climate_http_tests/tapes/climate_5_endpoints.tape"

// ---- Server-actor + scheduler-helper boilerplate (same as step 2). ----

message StartVCR { raw: ptr }
message Noop {}

actor VCRActor {
    state s = 0
    receive { StartVCR(raw) -> { s = raw; http_server_start_raw(raw) } }
}

actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

// ---- Recorder: proxy handler. ----------------------------------------
//
// Registered against each path the SUT will visit. Forwards the
// request to upstream via std.http.client, captures the response,
// echoes it back to the SUT verbatim, and calls vcr.record() so
// the captured exchange ends up on the tape.
//
// Why one handler per path rather than a catch-all: std.http.server's
// routing layer in v0.90 doesn't reliably match `/(.*)` regex
// patterns (we hit this when first writing the VCR). Per-path
// registration is the workaround. Any path the SUT visits that
// isn't registered here will return 404 from the framework's
// default handler — useful loud failure mode if the test author
// forgets to add a path.
//
// All five climate handlers share the same body — they only differ
// in the path string they use. We can't capture the path from `req`
// at runtime and reuse it because std.http.server doesn't expose
// path-pattern parameters in v0.90. So: five near-identical handlers,
// each hard-coding its path.

proxy_to(req: ptr, res: ptr, path: string) {
    // Forward the request to upstream. v0.1 only forwards the
    // method + URL, not the request headers — adequate for the
    // GitHub-Pages mirror which doesn't gate on headers.
    upstream_url = "${UPSTREAM_BASE}${path}"
    creq = client.request("GET", upstream_url)
    if creq == null {
        http.response_set_status(res, 599)
        http.response_set_body(res, "recorder: could not build upstream request")
        return
    }
    client.set_timeout(creq, 30)
    cresp, cerr = client.send_request(creq)
    client.request_free(creq)
    if cerr != "" {
        http.response_set_status(res, 599)
        http.response_set_body(res, "recorder: upstream transport: ${cerr}")
        return
    }

    status = client.response_status(cresp)
    body   = client.response_body(cresp)
    ctype_name = "Content-Type"
    ctype  = client.response_header(cresp, ctype_name)
    // Copy out before freeing — body and ctype are owned by cresp.
    body_owned  = string.copy(body)
    ctype_owned = string.copy(ctype)
    client.response_free(cresp)

    // Echo back to the SUT.
    http.response_set_status(res, status)
    if string.length(ctype_owned) > 0 {
        http.response_set_header(res, ctype_name, ctype_owned)
    }
    http.response_set_body(res, body_owned)

    // Capture for the tape.
    vcr.record("GET", path, status, ctype_owned, body_owned)
}

handle_gbr      (req: ptr, res: ptr, ud: ptr) { proxy_to(req, res, "/climateweb/rest/v1/country/annualavg/pr/1980/1999/gbr.xml") }
handle_fra      (req: ptr, res: ptr, ud: ptr) { proxy_to(req, res, "/climateweb/rest/v1/country/annualavg/pr/1980/1999/fra.xml") }
handle_egy      (req: ptr, res: ptr, ud: ptr) { proxy_to(req, res, "/climateweb/rest/v1/country/annualavg/pr/1980/1999/egy.xml") }
handle_gbr_bad  (req: ptr, res: ptr, ud: ptr) { proxy_to(req, res, "/climateweb/rest/v1/country/annualavg/pr/1985/1995/gbr.xml") }
handle_mde      (req: ptr, res: ptr, ud: ptr) { proxy_to(req, res, "/climateweb/rest/v1/country/annualavg/pr/1980/1999/mde.xml") }

// ---- Test helpers ----------------------------------------------------

close_enough(got: float, want: float) -> int {
    diff = got - want
    if diff < 0.0 { diff = 0.0 - diff }
    if diff < 0.0000001 { return 1 }
    return 0
}

// The 5 climate assertions, factored out so we can run them in
// either record or replay mode without duplicating.
run_assertions() {
    println("\nTest 1: gbr 1980-1999 mean rainfall")
    gbr, gerr = get_ave_annual_rainfall_from(VCR_BASE, 1980, 1999, "gbr")
    if gerr != "" { println("  FAIL: ${gerr}"); exit(1) }
    if close_enough(gbr, 988.8454972331015) != 1 {
        println("  FAIL: got ${gbr}, want 988.8454972331015"); exit(1)
    }
    println("  PASS: ${gbr}")

    println("\nTest 2: fra 1980-1999 mean rainfall")
    fra, ferr = get_ave_annual_rainfall_from(VCR_BASE, 1980, 1999, "fra")
    if ferr != "" { println("  FAIL: ${ferr}"); exit(1) }
    if close_enough(fra, 913.7986955122727) != 1 {
        println("  FAIL: got ${fra}, want 913.7986955122727"); exit(1)
    }
    println("  PASS: ${fra}")

    println("\nTest 3: egy 1980-1999 mean rainfall")
    egy, eerr = get_ave_annual_rainfall_from(VCR_BASE, 1980, 1999, "egy")
    if eerr != "" { println("  FAIL: ${eerr}"); exit(1) }
    if close_enough(egy, 54.58587712129825) != 1 {
        println("  FAIL: got ${egy}, want 54.58587712129825"); exit(1)
    }
    println("  PASS: ${egy}")

    println("\nTest 4: gbr 1985-1995 — unsupported date range")
    _, derr = get_ave_annual_rainfall_from(VCR_BASE, 1985, 1995, "gbr")
    if string.contains(derr, "date range not supported") != 1 {
        println("  FAIL: expected date-range error, got '${derr}'"); exit(1)
    }
    println("  PASS: '${derr}'")

    println("\nTest 5: mde — bad country code")
    _, mderr = get_ave_annual_rainfall_from(VCR_BASE, 1980, 1999, "mde")
    if string.contains(mderr, "bad country code") != 1 {
        println("  FAIL: expected bad-country error, got '${mderr}'"); exit(1)
    }
    println("  PASS: '${mderr}'")
}

main() {
    if io.getenv("AETHER_SKIP_NETWORK") != 0 {
        // Replay-only mode is fine offline; record mode isn't.
        // If we'd be recording, skip; if a tape exists, run replay.
        if file_exists(TAPE_PATH) == 0 {
            println("SKIP test_climate_record_then_replay: AETHER_SKIP_NETWORK and no tape")
            return
        }
        // else fall through to replay
    }

    println("=== contrib.climate_http_tests record-then-replay ===\n")

    // Three modes, decided once up front:
    //   - is_recording = 1, is_rechecking = 0
    //       no tape, AETHER_VCR_RECORD irrelevant → proxy + flush
    //   - is_recording = 1, is_rechecking = 1
    //       tape present, AETHER_VCR_RECORD set → proxy + flush_or_check
    //       (Servirtium step 4 — upstream-drift / client-drift detection)
    //   - is_recording = 0, is_rechecking = 0
    //       tape present, AETHER_VCR_RECORD unset → replay
    is_recording = 0
    is_rechecking = 0
    tape_present = 0
    if file_exists(TAPE_PATH) != 0 { tape_present = 1 }
    force_record = 0
    if io.getenv("AETHER_VCR_RECORD") != 0 { force_record = 1 }

    if tape_present == 0 {
        is_recording = 1
        println("(no tape at ${TAPE_PATH} — recording from upstream)")
    } else if force_record == 1 {
        is_recording = 1
        is_rechecking = 1
        println("(tape present + AETHER_VCR_RECORD set — re-recording with byte-diff check)")
    } else {
        println("(tape present at ${TAPE_PATH} — replaying)")
    }

    raw = http.server_create(PORT)
    if raw == 0 { println("FAIL: server_create"); exit(1) }

    if is_recording == 1 {
        // Register one proxy handler per path. The recorder doesn't
        // need a tape loaded — it builds the in-memory tape array
        // as it captures.
        http.server_get(raw, "/climateweb/rest/v1/country/annualavg/pr/1980/1999/gbr.xml", handle_gbr,     0)
        http.server_get(raw, "/climateweb/rest/v1/country/annualavg/pr/1980/1999/fra.xml", handle_fra,     0)
        http.server_get(raw, "/climateweb/rest/v1/country/annualavg/pr/1980/1999/egy.xml", handle_egy,     0)
        http.server_get(raw, "/climateweb/rest/v1/country/annualavg/pr/1985/1995/gbr.xml", handle_gbr_bad, 0)
        http.server_get(raw, "/climateweb/rest/v1/country/annualavg/pr/1980/1999/mde.xml", handle_mde,     0)
    } else {
        // Replay mode: load the tape and let the existing dispatcher
        // serve from it. Skip the manual server_create above —
        // vcr.load() does its own. So we redo it.
        http.server_stop(raw)
        raw = vcr.load(TAPE_PATH, PORT)
        if raw == null { println("FAIL: vcr.load"); exit(1) }
    }

    spawn(SchedHelper())
    a = spawn(VCRActor())
    a ! StartVCR { raw: raw }
    sleep(500)

    run_assertions()

    if is_recording == 1 {
        if is_rechecking == 1 {
            // Re-record check: write to a sibling .actual then byte-diff
            // against the on-disk tape. Mismatch → fail loud with the
            // diff offset. The .actual sibling is left on disk so the
            // developer can inspect both and decide whether to update
            // the committed tape or fix the client/upstream.
            check_err = vcr.flush_or_check(TAPE_PATH)
            if check_err != "" {
                println("\nFAIL: re-record diverged from committed tape:")
                println("  ${check_err}")
                exit(1)
            }
            println("\nRe-record check passed: ${vcr.tape_length()} interactions byte-identical to ${TAPE_PATH}")
        } else {
            flush_err = vcr.flush(TAPE_PATH)
            if flush_err != "" {
                println("FAIL: tape flush: ${flush_err}"); exit(1)
            }
            println("\nWrote ${vcr.tape_length()} interactions to ${TAPE_PATH}")
            println("Re-run this test to exercise the replay path.")
        }
    }

    println("\n=== All 5 record-then-replay tests passed ===")
    vcr.eject(raw)
    exit(0)
}

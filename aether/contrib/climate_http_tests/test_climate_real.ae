// Step 1 of the Servirtium roadmap (servirtium.dev →
// starting-a-new-implementation.md): five tests against the real
// climate API. No Servirtium / VCR involvement at this step — this
// is the test harness that will later be re-run through the VCR
// replayer in step 2 to prove they yield identical assertions.
//
// All five tests come from the README's prescribed pseudo-code:
//
//   test_averageRainfallForGreatBritainFrom1980to1999Exists()
//       == 988.8454972331015
//   test_averageRainfallForFranceFrom1980to1999Exists()
//       == 913.7986955122727
//   test_averageRainfallForEgyptFrom1980to1999Exists()
//       == 54.58587712129825
//   test_averageRainfallForGreatBritainFrom1985to1995DoesNotExist()
//       → "date range not supported"
//   test_averageRainfallForMiddleEarthFrom1980to1999DoesNotExist()
//       → "bad country code"
//
// Real-network: hits the GitHub-Pages mirror over HTTPS. Skips
// when AETHER_SKIP_NETWORK is set so offline runners still pass.

import contrib.climate_http_tests.get_ave_annual_rainfall_from
import contrib.climate_http_tests.DEFAULT_BASE
import std.http.client   // transitively used by climate; required at the
                          // test's typecheck site for the qualified
                          // `client.*` calls inside the inlined module
                          // body to resolve.
import std.string
import std.io

extern exit(code: int)

// Float compare with tolerance — the README's expected values are
// to 13 decimal places but we want to be robust to last-bit
// rounding differences across libc implementations.
close_enough(got: float, want: float) -> int {
    diff = got - want
    if diff < 0.0 { diff = 0.0 - diff }
    if diff < 0.0000001 { return 1 }
    return 0
}

main() {
    if io.getenv("AETHER_SKIP_NETWORK") != 0 {
        println("SKIP test_climate_api_real: AETHER_SKIP_NETWORK set")
        return
    }

    println("=== contrib.climate_http_tests real-network tests ===\n")

    println("Test 1: gbr 1980-1999 mean rainfall")
    gbr, gerr = get_ave_annual_rainfall_from(DEFAULT_BASE, 1980, 1999, "gbr")
    if gerr != "" { println("  FAIL transport/server: ${gerr}"); exit(1) }
    if close_enough(gbr, 988.8454972331015) != 1 {
        println("  FAIL: got ${gbr}, want 988.8454972331015")
        exit(1)
    }
    println("  PASS: ${gbr}")

    println("\nTest 2: fra 1980-1999 mean rainfall")
    fra, ferr = get_ave_annual_rainfall_from(DEFAULT_BASE, 1980, 1999, "fra")
    if ferr != "" { println("  FAIL: ${ferr}"); exit(1) }
    if close_enough(fra, 913.7986955122727) != 1 {
        println("  FAIL: got ${fra}, want 913.7986955122727")
        exit(1)
    }
    println("  PASS: ${fra}")

    println("\nTest 3: egy 1980-1999 mean rainfall")
    egy, eerr = get_ave_annual_rainfall_from(DEFAULT_BASE, 1980, 1999, "egy")
    if eerr != "" { println("  FAIL: ${eerr}"); exit(1) }
    if close_enough(egy, 54.58587712129825) != 1 {
        println("  FAIL: got ${egy}, want 54.58587712129825")
        exit(1)
    }
    println("  PASS: ${egy}")

    println("\nTest 4: gbr 1985-1995 — unsupported date range")
    _, derr = get_ave_annual_rainfall_from(DEFAULT_BASE, 1985, 1995, "gbr")
    if string.contains(derr, "date range not supported") != 1 {
        println("  FAIL: expected date-range error, got '${derr}'")
        exit(1)
    }
    println("  PASS: '${derr}'")

    println("\nTest 5: mde — bad country code")
    _, mderr = get_ave_annual_rainfall_from(DEFAULT_BASE, 1980, 1999, "mde")
    if string.contains(mderr, "bad country code") != 1 {
        println("  FAIL: expected bad-country error, got '${mderr}'")
        exit(1)
    }
    println("  PASS: '${mderr}'")

    println("\n=== All 5 climate API tests passed ===")
}
